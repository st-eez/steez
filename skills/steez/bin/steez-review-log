#!/usr/bin/env bash
# steez-review-log — atomically log a review result
# Usage: steez-review-log '{"skill":"...","timestamp":"...","status":"..."}'
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
eval "$("$SCRIPT_DIR/steez-slug" 2>/dev/null)"
STEEZ_HOME="${STEEZ_HOME:-$HOME/.steez}"
mkdir -p "$STEEZ_HOME/projects/$SLUG"

# Validate: input must be parseable JSON (reject malformed or injection attempts)
INPUT="$1"
if ! printf '%s' "$INPUT" | bun -e "JSON.parse(await Bun.stdin.text())" 2>/dev/null; then
  # Not valid JSON — refuse to append
  echo "steez-review-log: invalid JSON, skipping" >&2
  exit 1
fi

echo "$INPUT" >> "$STEEZ_HOME/projects/$SLUG/$BRANCH-reviews.jsonl"
