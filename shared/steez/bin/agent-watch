#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'USAGE'
Usage: agent-watch add <pane> [--spawner <pane>] [--label <str>] [--baseline <state>]
       agent-watch remove <pane>
       agent-watch list
       agent-watch daemon-status

Public CLI for the event-driven watch service. Every subcommand routes
to agent-eventsd. Manual add emits turn.prearm followed by watch.start
immediately (no prompt bytes in between). agent-send is the only
two-step-turn caller that inserts prompt delivery between prearm and
start.

Notifications are delivered via agent-deliver (never agent-send) to
prevent recursive notification loops.

Commands:
  add <pane>       Prearm + start a watch on <pane> (armed immediately).
  remove <pane>    Close the live watch on <pane>.
  list             Print the current watchlist.
  daemon-status    Report agent-eventsd health.

Options for `add`:
  --spawner <pane>    Pane to notify when the watched pane finishes.
                      Defaults to $TMUX_PANE (the caller's pane).
  --label <str>       Short label shown in the notification message.
                      Defaults to the agent type (ren, claude, codex, etc).
  --baseline <state>  Initial state to compare against. The daemon fires
                      when the observed state differs from baseline and
                      is one of {idle, blocked:question, blocked:permission,
                      blocked:unknown}. Defaults to "working".
USAGE
  exit 0
}

AGENT_EVENTSD="$HOME/.steez/bin/agent-eventsd"
AGENT_STATE="$HOME/.steez/bin/agent-state"

resolve_pane_id() {
  local raw="$1"
  local resolved
  resolved=$(tmux display-message -t "$raw" -p '#{pane_id}' 2>/dev/null || true)
  if [[ -n "$resolved" ]]; then
    printf '%s' "$resolved"
  else
    printf '%s' "$raw"
  fi
}

infer_label() {
  local pane="$1" state_json agent
  state_json=$("$AGENT_STATE" "$pane" 2>/dev/null || true)
  if [[ -n "$state_json" ]]; then
    agent=$(printf '%s' "$state_json" | jq -r '.agent // empty' 2>/dev/null || true)
    if [[ -n "$agent" ]]; then
      printf '%s' "$agent"
      return 0
    fi
  fi
  printf 'agent'
}

cmd_add() {
  [[ $# -gt 0 ]] || { echo "error: agent-watch add requires a pane" >&2; exit 1; }

  local pane_raw="$1"; shift
  local spawner_raw="${TMUX_PANE:-}"
  local label=""
  local baseline="working"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --spawner)  spawner_raw="$2"; shift 2 ;;
      --label)    label="$2"; shift 2 ;;
      --baseline) baseline="$2"; shift 2 ;;
      -h|--help)  usage ;;
      *) echo "error: unknown arg '$1'" >&2; exit 1 ;;
    esac
  done

  [[ -n "$pane_raw" ]] || { echo "error: pane required" >&2; exit 1; }
  [[ -n "$spawner_raw" ]] || { echo "error: --spawner required (no \$TMUX_PANE to fall back on)" >&2; exit 1; }

  local pane spawner
  pane=$(resolve_pane_id "$pane_raw")
  spawner=$(resolve_pane_id "$spawner_raw")

  if [[ -z "$label" ]]; then
    label=$(infer_label "$pane")
  fi

  # Spec (Watch lifecycle — armed): manual add uses the same two-step
  # turn as agent-send, but watch.start follows turn.prearm immediately
  # (no prompt bytes in between). Both calls run synchronously so the
  # caller's exit code reflects wire-up success — unlike agent-send,
  # manual add has no separate delivery contract to protect.
  local wid
  wid=$("$AGENT_EVENTSD" prearm \
    --pane "$pane" --spawner "$spawner" \
    --label "$label" --baseline-state "$baseline") || {
    echo "error: prearm failed" >&2
    exit 1
  }
  "$AGENT_EVENTSD" start --pane "$pane" --watch-id "$wid" >/dev/null || {
    echo "error: watch.start failed (watch will time out as pending)" >&2
    exit 1
  }

  echo "watching $pane <- $spawner ($label, baseline=$baseline)"
}

cmd_remove() {
  [[ $# -gt 0 ]] || { echo "error: agent-watch remove requires a pane" >&2; exit 1; }
  local pane_raw="$1"
  local pane
  pane=$(resolve_pane_id "$pane_raw")
  "$AGENT_EVENTSD" remove "$pane" >/dev/null 2>&1 || true
  echo "removed watch on $pane"
}

cmd_list() {
  local out
  out=$("$AGENT_EVENTSD" list 2>/dev/null || true)
  if [[ -z "$out" ]]; then
    echo "(no active watches)"
    return
  fi
  # Live watches (pending/armed) are the interesting set for listing —
  # draining watches (resolved/delivering/...) are transient and not
  # something the user can act on.
  local live
  live=$(printf '%s' "$out" | jq -r '
    select(.state == "pending" or .state == "armed")
    | "\(.pane_id)  <- \(.spawner_pane)  [\(.label)]  baseline=\(.baseline_state)  state=\(.state)"
  ')
  if [[ -z "$live" ]]; then
    echo "(no active watches)"
  else
    printf '%s\n' "$live"
  fi
}

cmd_daemon_status() {
  # Bead 8 acceptance: "daemon-status reports agent-eventsd health." The
  # primary path is agent-eventsd.
  local out rc=0
  out=$("$AGENT_EVENTSD" status 2>/dev/null) || rc=$?
  if [[ $rc -eq 0 ]]; then
    echo "agent-eventsd: $out"
    return 0
  fi
  echo "agent-eventsd: unavailable"
  return 1
}

main() {
  [[ $# -gt 0 ]] || usage
  local cmd="$1"; shift
  case "$cmd" in
    add)           cmd_add "$@" ;;
    remove|rm)     cmd_remove "$@" ;;
    list|ls)       cmd_list "$@" ;;
    daemon-status) cmd_daemon_status "$@" ;;
    -h|--help)     usage ;;
    *) echo "error: unknown command '$cmd'" >&2; usage ;;
  esac
}

main "$@"
