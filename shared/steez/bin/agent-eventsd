#!/usr/bin/env bash
# agent-eventsd — event-driven watch daemon for AI agent panes.
#
# Bead 1 scope (kernel): per-pane seq assigner, watch record struct,
# in-memory store with live/draining partitions. No lifecycle
# transitions, no resolver, no transport. See specs/agent-events.md.
#
# The kernel is a pure library: sourcing this file defines functions
# and does not start a daemon. A later bead adds the transport layer
# and a main entrypoint.

set -uo pipefail

# State lives under STEEZ_STATE_DIR so the daemon can recover across
# restarts (spec: Pane close and restart). The store is keyed by
# pane. Each pane has its own seq counter.
_EVENTSD_STATE_DIR="${STEEZ_STATE_DIR:-$HOME/.steez/state}/eventsd"

# Spec defaults. Tests may override via env before sourcing or before
# calling a lifecycle transition. The daemon reads them at call time so
# overrides always win.
: "${MAX_DELIVERY_ATTEMPTS:=5}"
: "${AGENT_DELIVER_CMD:=agent-deliver}"
: "${AGENT_STATE_CMD:=agent-state}"
: "${SILENCE_WINDOW_MS:=30000}"
: "${RECONCILE_INTERVAL_MS:=5000}"
: "${INDETERMINATE_TIMEOUT_MS:=120000}"
: "${PREARM_TIMEOUT_MS:=5000}"

# Monotonic clock in ms. Tests set EVENTSD_NOW_MS to drive the fake clock
# deterministically. Real daemon reads wall time; sub-second precision is
# not required by the spec, so a ms-from-seconds reading is fine.
_eventsd_now_ms() {
  if [[ -n "${EVENTSD_NOW_MS:-}" ]]; then
    printf '%s' "$EVENTSD_NOW_MS"
    return
  fi
  printf '%s' "$(( $(date +%s) * 1000 ))"
}

# Map arbitrary pane ids (e.g. '%42', 'main:0.1') to filesystem-safe
# keys. Non-alphanumerics become '_'. Collisions are possible in
# theory but not in the pane-id grammar tmux actually emits.
_eventsd_pane_key() {
  local raw="$1"
  printf '%s' "${raw//[^a-zA-Z0-9]/_}"
}

# _eventsd_atomic_write <target> <content>
# Write <content> to <target> atomically: stage to a sibling temp file,
# then rename onto <target>. Readers see either the prior complete file
# or the new complete file — never a truncated view. A crash between
# stage and rename leaves the prior value intact; the stranded temp
# file is cleanup debt, not a correctness hazard.
#
# Callers must have ensured dirname <target> exists.
#
# _eventsd_test_hook_post_stage is a test seam invoked between stage
# and rename. Production never defines it.
_eventsd_atomic_write() {
  local target="$1" content="$2"
  local tmp
  tmp=$(mktemp "${target}.XXXXXX") || return 1
  printf '%s' "$content" > "$tmp" || { rm -f "$tmp"; return 1; }
  if declare -F _eventsd_test_hook_post_stage >/dev/null 2>&1; then
    _eventsd_test_hook_post_stage "$target" "$tmp"
  fi
  mv -f "$tmp" "$target"
}

# seq_next <pane> — assign the next monotonic seq for <pane> and
# print it. Counter is independent per pane. First call returns 1.
seq_next() {
  local pane="$1"
  local key dir file cur next
  key=$(_eventsd_pane_key "$pane")
  dir="$_EVENTSD_STATE_DIR/seq"
  file="$dir/$key"
  mkdir -p "$dir"
  if [[ -f "$file" ]]; then
    cur=$(cat "$file")
  else
    cur=0
  fi
  next=$((cur + 1))
  _eventsd_atomic_write "$file" "$next"
  printf '%s' "$next"
}

# ----- watch store -----
#
# Storage layout (canonical, file-backed for daemon-restart recovery):
#   $_EVENTSD_STATE_DIR/watches/<watch_id>.json  — one record per watch
#   $_EVENTSD_STATE_DIR/index/live/<pane_key>    — file with watch_id
#   $_EVENTSD_STATE_DIR/index/draining/<pane_key> — newline list
#
# Bead 1 never populates the draining index because no lifecycle
# transition exists that moves a watch out of live. Later beads own
# those transitions and will write the draining index.

_eventsd_gen_id() {
  if command -v uuidgen >/dev/null 2>&1; then
    uuidgen | tr '[:upper:]' '[:lower:]'
  else
    printf '%s-%s-%s' "$(date +%s)" "$$" "$RANDOM$RANDOM"
  fi
}

_eventsd_watch_file() {
  printf '%s/watches/%s.json' "$_EVENTSD_STATE_DIR" "$1"
}

# Per-watch pre-arm evidence buffer. One JSONL file per watch, appended in
# arrival order. Consumed and removed by _eventsd_flush_buffer on arm, and
# by _eventsd_close on pending-state close/remove.
_eventsd_buffer_file() {
  printf '%s/buffer/%s.jsonl' "$_EVENTSD_STATE_DIR" "$1"
}

_eventsd_attention_file() {
  printf '%s/attention/%s.json' "$_EVENTSD_STATE_DIR" "$(_eventsd_pane_key "$1")"
}

_eventsd_attention_summary() {
  case "$1" in
    idle) printf '%s' "turn complete" ;;
    blocked:question) printf '%s' "waiting for question answer" ;;
    blocked:permission) printf '%s' "waiting for permission approval" ;;
    blocked:unknown) printf '%s' "waiting at unknown prompt" ;;
    *) printf '%s' "working" ;;
  esac
}

_eventsd_live_resolving_state() {
  case "$1" in
    idle|blocked:question|blocked:permission) return 0 ;;
    *) return 1 ;;
  esac
}

attention_get_recent() {
  local file
  file=$(_eventsd_attention_file "$1")
  [[ -f "$file" ]] && cat "$file"
}

_eventsd_record_attention() {
  local pane="$1" state="$2" source="${3:-eventsd}" transcript_cursor="${4:-}"
  local summary="${5:-}" detail="${6:-}" spawner_pane="${7:-}"
  local session_id="" transcript_path=""
  session_id=$(tmux show-options -pv -t "$pane" @session_id 2>/dev/null || true)
  transcript_path=$(tmux show-options -pv -t "$pane" @transcript_path 2>/dev/null || true)
  [[ -n "$summary" ]] || summary=$(_eventsd_attention_summary "$state")

  local now file rec
  now=$(_eventsd_now_ms)
  file=$(_eventsd_attention_file "$pane")
  mkdir -p "$(dirname "$file")"
  rec=$(jq -nc \
    --arg pane "$pane" \
    --arg state "$state" \
    --arg summary "$summary" \
    --arg source "$source" \
    --arg session_id "$session_id" \
    --arg transcript_path "$transcript_path" \
    --arg transcript_cursor "$transcript_cursor" \
    --arg detail "$detail" \
    --arg spawner_pane "$spawner_pane" \
    --argjson observed_at_ms "$now" \
    '{
       pane_id: $pane,
       state: $state,
       summary: $summary,
       source: $source,
       observed_at_ms: $observed_at_ms
     }
     + (if $session_id != "" then {session_id: $session_id} else {} end)
     + (if $transcript_path != "" then {transcript_path: $transcript_path} else {} end)
     + (if $transcript_cursor != "" then {transcript_cursor: ($transcript_cursor | tonumber)} else {} end)
     + (if $detail != "" then {detail: $detail} else {} end)
     + (if $spawner_pane != "" then {spawner_pane: $spawner_pane} else {} end)')
  _eventsd_atomic_write "$file" "${rec}"$'\n'
  _eventsd_refresh_spawner_sink "$spawner_pane"
}

# _eventsd_clear_attention <pane>
# Unlink the pane's attention record, then refresh the spawner-scoped
# tmux sink so the dot reflects whatever attention records still exist
# for that spawner. Called on turn.prearm — the turn-boundary event that
# invalidates the prior terminal record for the same worker. Pane-close
# intentionally does NOT call this: attention must survive worker death
# (sticky) until a new turn.prearm retires the record.
#
# Reads the spawner from the stored record before unlinking so the
# refresh pass lands on the correct window even when the caller has no
# live watch context. Idempotent: absent file skips the unlink and the
# refresh pass still runs against any spawner value we could recover.
_eventsd_clear_attention() {
  local pane="$1" file spawner=""
  file=$(_eventsd_attention_file "$pane")
  if [[ -f "$file" ]]; then
    spawner=$(jq -r '.spawner_pane // empty' "$file" 2>/dev/null || true)
  fi
  rm -f "$file"
  _eventsd_refresh_spawner_sink "$spawner"
}

# _eventsd_refresh_spawner_sink <spawner_pane>
# Drive the spawner-scoped tmux window option off the on-disk attention
# aggregate. The dot represents "any watched worker spawned from this
# window has unread attention." Per-worker attention records stay
# worker-keyed on disk for `agent-state <pane> --explain`; this helper
# collapses them into a single presence bit on the spawner's window.
#
# If any attention record carries `.spawner_pane == <spawner>`, the
# window option is set to the first such record's state (the exact
# value doesn't matter to the tmux format, which only checks presence —
# #{?@agent_monitor_attention, ●,}). With no records, the option is
# unset so the dot clears. SketchyBar is triggered either way so
# macOS-bar consumers refresh on every attention change.
#
# Empty spawner_pane still triggers SketchyBar but skips the tmux call —
# we have no window to target. tmux/jq absence is best-effort.
_eventsd_refresh_spawner_sink() {
  local spawner="$1"
  if [[ -z "$spawner" ]]; then
    _eventsd_trigger_sketchybar_attention_changed
    return 0
  fi
  command -v tmux >/dev/null 2>&1 || { _eventsd_trigger_sketchybar_attention_changed; return 0; }
  local dir="$_EVENTSD_STATE_DIR/attention"
  local state="" f s
  if [[ -d "$dir" ]]; then
    for f in "$dir"/*.json; do
      [[ -f "$f" ]] || continue
      s=$(jq -r --arg sp "$spawner" \
            'select((.spawner_pane // "") == $sp) | .state // empty' \
            "$f" 2>/dev/null) || continue
      if [[ -n "$s" ]]; then
        state="$s"
        break
      fi
    done
  fi
  if [[ -z "$state" ]]; then
    tmux set-option -w -u -t "$spawner" @agent_monitor_attention \
      >/dev/null 2>&1 || true
  else
    tmux set-option -w -t "$spawner" @agent_monitor_attention "$state" \
      >/dev/null 2>&1 || true
  fi
  _eventsd_trigger_sketchybar_attention_changed
}

# _eventsd_trigger_sketchybar_attention_changed
# Fire the SketchyBar agent_attention_changed trigger so the macOS bar
# item refreshes immediately instead of waiting for its slow fallback
# poll. Best-effort: missing sketchybar is not an error.
_eventsd_trigger_sketchybar_attention_changed() {
  command -v sketchybar >/dev/null 2>&1 || return 0
  sketchybar --trigger agent_attention_changed >/dev/null 2>&1 || true
}

# _eventsd_ack_spawner_attention <spawner_pane>
# First-class ack/read path for sticky spawner-scoped attention.
# Retires every attention record whose stored `spawner_pane` matches
# <spawner_pane> by unlinking it from disk, then runs a single refresh
# pass so the tmux window option unsets and SketchyBar re-reads. Other
# spawners' records are untouched: the scan filters on the stored
# `spawner_pane` field, and the refresh pass targets the acknowledged
# window only.
#
# A single refresh at the end is load-bearing. Calling clear-per-file
# would fire one tmux set-option and one sketchybar trigger per worker,
# producing flapping state and N extra subprocess spawns for no
# behavior gain.
_eventsd_ack_spawner_attention() {
  local spawner="$1"
  [[ -n "$spawner" ]] || { echo "_eventsd_ack_spawner_attention: missing spawner" >&2; return 2; }
  local dir="$_EVENTSD_STATE_DIR/attention"
  if [[ -d "$dir" ]]; then
    local f sp
    for f in "$dir"/*.json; do
      [[ -f "$f" ]] || continue
      sp=$(jq -r '.spawner_pane // empty' "$f" 2>/dev/null) || continue
      [[ "$sp" == "$spawner" ]] || continue
      rm -f "$f"
    done
  fi
  _eventsd_refresh_spawner_sink "$spawner"
}

_eventsd_buffer_evidence() {
  local wid="$1" seq="$2" state="$3"
  local has_cursor="$4" cursor="$5" has_hash="$6" hash="$7"
  local file
  file=$(_eventsd_buffer_file "$wid")
  mkdir -p "$(dirname "$file")"
  local rec
  if (( has_cursor )) && (( has_hash )); then
    rec=$(jq -cn --argjson seq "$seq" --arg state "$state" \
      --argjson cursor "$cursor" --arg hash "$hash" \
      '{seq:$seq,state:$state,cursor:$cursor,hash:$hash}')
  elif (( has_cursor )); then
    rec=$(jq -cn --argjson seq "$seq" --arg state "$state" \
      --argjson cursor "$cursor" \
      '{seq:$seq,state:$state,cursor:$cursor}')
  elif (( has_hash )); then
    rec=$(jq -cn --argjson seq "$seq" --arg state "$state" \
      --arg hash "$hash" \
      '{seq:$seq,state:$state,hash:$hash}')
  else
    rec=$(jq -cn --argjson seq "$seq" --arg state "$state" \
      '{seq:$seq,state:$state}')
  fi
  printf '%s\n' "$rec" >> "$file"
}

# Replay buffered evidence through the resolver in arrival order. Stops at
# the first event that resolves (or otherwise moves) the watch out of
# armed. The buffer file is removed on completion regardless of outcome.
_eventsd_flush_buffer() {
  local wid="$1"
  local file
  file=$(_eventsd_buffer_file "$wid")
  [[ -f "$file" ]] || return 0
  local line seq state cursor hash cur cur_state
  while IFS= read -r line; do
    [[ -n "$line" ]] || continue
    cur=$(watch_get "$wid")
    cur_state=$(printf '%s' "$cur" | jq -r .state)
    [[ "$cur_state" == "armed" ]] || break
    seq=$(printf '%s' "$line" | jq -r .seq)
    state=$(printf '%s' "$line" | jq -r .state)
    cursor=$(printf '%s' "$line" | jq -r '.cursor // empty')
    hash=$(printf '%s' "$line" | jq -r '.hash // empty')
    local args=(--watch-id "$wid" --seq "$seq" --candidate-state "$state")
    [[ -n "$cursor" ]] && args+=(--transcript-cursor "$cursor")
    [[ -n "$hash" ]] && args+=(--screen-hash "$hash")
    watch_feed_evidence "${args[@]}" >/dev/null || true
  done < "$file"
  rm -f "$file"
}

_eventsd_live_file() {
  printf '%s/index/live/%s' "$_EVENTSD_STATE_DIR" "$(_eventsd_pane_key "$1")"
}

_eventsd_draining_file() {
  printf '%s/index/draining/%s' "$_EVENTSD_STATE_DIR" "$(_eventsd_pane_key "$1")"
}

# _eventsd_add_draining <pane> <watch_id>
# Append <watch_id> to the pane's draining ledger. The ledger records every
# watch that has left the live slot but has not yet finished delivery
# (spec: Live and draining watches — resolved, delivering, delivery_failed).
# Many draining watches may coexist per pane; they are independent of the
# live slot and of each other.
_eventsd_add_draining() {
  local pane="$1" wid="$2" file
  file=$(_eventsd_draining_file "$pane")
  mkdir -p "$(dirname "$file")"
  printf '%s\n' "$wid" >> "$file"
}

# _eventsd_remove_draining <pane> <watch_id>
# Drop <watch_id> from the pane's draining ledger. Called when a draining
# watch reaches a terminal delivery outcome (delivered or delivery_exhausted).
# Idempotent: missing file or missing id is a no-op.
_eventsd_remove_draining() {
  local pane="$1" wid="$2" file
  file=$(_eventsd_draining_file "$pane")
  [[ -f "$file" ]] || return 0
  local tmp
  tmp=$(mktemp "${file}.XXXXXX")
  grep -Fvx -- "$wid" "$file" > "$tmp" || true
  if [[ -s "$tmp" ]]; then
    mv "$tmp" "$file"
  else
    rm -f "$tmp" "$file"
  fi
}

# watch_create_pending — materialize a pending watch record.
#
# Flags:
#   --pane <id>                    (required)
#   --spawner <id>                 (required)
#   --label <string>               (required)
#   --baseline-state <state>       (required)
#   --prearm-screen-hash <hash>    (required)
#   --prearm-transcript-cursor <n> (required)
#   --prearm-seq <n>               (required)
#   --turn-id <id>                 (optional, auto-generated)
#   --watch-id <id>                (optional, auto-generated)
#
# Prints watch_id on success. Exits non-zero if the pane already has
# a live watch (at-most-one-live invariant; spec: Live and draining
# watches). Lifecycle transitions that would free the slot live in a
# later bead.
watch_create_pending() {
  local pane="" spawner="" label="" baseline="" hash="" cursor="" prearm_seq=""
  local watch_id="" turn_id=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --pane) pane="$2"; shift 2 ;;
      --spawner) spawner="$2"; shift 2 ;;
      --label) label="$2"; shift 2 ;;
      --baseline-state) baseline="$2"; shift 2 ;;
      --prearm-screen-hash) hash="$2"; shift 2 ;;
      --prearm-transcript-cursor) cursor="$2"; shift 2 ;;
      --prearm-seq) prearm_seq="$2"; shift 2 ;;
      --turn-id) turn_id="$2"; shift 2 ;;
      --watch-id) watch_id="$2"; shift 2 ;;
      *) echo "watch_create_pending: unknown flag: $1" >&2; return 2 ;;
    esac
  done

  local f
  for f in pane spawner label baseline hash cursor prearm_seq; do
    if [[ -z "${!f}" ]]; then
      echo "watch_create_pending: missing --${f//_/-}" >&2
      return 2
    fi
  done

  # Spec (Live and draining watches): "A new turn.prearm supersedes any
  # existing live watch on that pane without waiting for draining delivery
  # to finish." The prior live watch closes with close_reason=superseded
  # (spec: watch lifecycle — "Explicit removal or live-watch supersession
  # closes an unresolved watch without delivery"). Draining watches on the
  # same pane are untouched — they occupy the draining ledger, not the
  # live slot.
  local live_file
  live_file=$(_eventsd_live_file "$pane")
  if [[ -s "$live_file" ]]; then
    local prior_wid
    prior_wid=$(cat "$live_file")
    _eventsd_close "$prior_wid" "$pane" "superseded"
  fi

  # Turn boundary: any attention record from a prior turn is stale now.
  # Unlink so inspectors do not surface a prior terminal state against
  # the new turn, and propagate the clear to the inline sinks.
  _eventsd_clear_attention "$pane"

  [[ -n "$watch_id" ]] || watch_id=$(_eventsd_gen_id)
  [[ -n "$turn_id" ]] || turn_id=$(_eventsd_gen_id)

  mkdir -p "$_EVENTSD_STATE_DIR/watches" "$_EVENTSD_STATE_DIR/index/live"

  local record
  record=$(jq -cn \
    --arg watch_id "$watch_id" \
    --arg turn_id "$turn_id" \
    --arg pane_id "$pane" \
    --arg spawner_pane "$spawner" \
    --arg label "$label" \
    --arg baseline_state "$baseline" \
    --arg prearm_screen_hash "$hash" \
    --argjson prearm_transcript_cursor "$cursor" \
    --argjson prearm_seq "$prearm_seq" \
    '{
       watch_id: $watch_id,
       turn_id: $turn_id,
       pane_id: $pane_id,
       spawner_pane: $spawner_pane,
       label: $label,
       baseline_state: $baseline_state,
       prearm_screen_hash: $prearm_screen_hash,
       prearm_transcript_cursor: $prearm_transcript_cursor,
       prearm_seq: $prearm_seq,
       start_seq: null,
       state: "pending"
     }')

  printf '%s\n' "$record" > "$(_eventsd_watch_file "$watch_id")"
  printf '%s' "$watch_id" > "$live_file"
  printf '%s' "$watch_id"
}

# watch_get <watch_id> — print the stored record (compact JSON) or
# nothing if it does not exist. Private helper.
watch_get() {
  local file
  file=$(_eventsd_watch_file "$1")
  [[ -f "$file" ]] && cat "$file"
}

# watch_get_live <pane> — print the live watch record for pane, or
# nothing if the pane has no live watch.
watch_get_live() {
  local live_file wid
  live_file=$(_eventsd_live_file "$1")
  [[ -s "$live_file" ]] || return 0
  wid=$(cat "$live_file")
  watch_get "$wid"
}

# watch_get_draining <pane> — print JSONL (one record per line) for
# every draining watch on pane. Bead 1 always returns nothing
# because no transition populates the draining index yet.
watch_get_draining() {
  local draining_file wid
  draining_file=$(_eventsd_draining_file "$1")
  [[ -f "$draining_file" ]] || return 0
  while IFS= read -r wid; do
    [[ -n "$wid" ]] || continue
    watch_get "$wid"
  done < "$draining_file"
}

# _eventsd_write_record <watch_id> <json>
# Writes the on-disk record for a watch. For active states the write is a
# temp+rename atomic replacement. For terminal states (delivered, closed)
# the record is unlinked instead — no runtime path reads a post-terminal
# record (retry paths read `delivery_failed`; resolve, feed_evidence, tick
# and deliver_attempt are one-shot against terminal state), so leaving the
# file on disk was pure accumulation. A single production snapshot showed
# 148 delivered + 11 closed stranded files (bead steez-u7o7.1).
_eventsd_write_record() {
  local wid="$1" json="$2" state
  state=$(printf '%s' "$json" | jq -r '.state // empty' 2>/dev/null || true)
  case "$state" in
    delivered|closed)
      rm -f "$(_eventsd_watch_file "$wid")"
      ;;
    *)
      _eventsd_atomic_write "$(_eventsd_watch_file "$wid")" "${json}"$'\n'
      ;;
  esac
}

# watch_arm — promote a pending watch to armed (spec: watch.start).
#
# Flags:
#   --pane <id>       (required) pane carrying the live pending watch
#   --watch-id <id>   (required) must match the pane's live watch_id
#   --start-seq <n>   (required) monotonic seq assigned to watch.start
#
# Rejects (non-zero) when the pane has no live watch, the live watch_id
# does not match, or the watch is not in `pending`.
watch_arm() {
  local pane="" wid="" start_seq=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --pane) pane="$2"; shift 2 ;;
      --watch-id) wid="$2"; shift 2 ;;
      --start-seq) start_seq="$2"; shift 2 ;;
      *) echo "watch_arm: unknown flag: $1" >&2; return 2 ;;
    esac
  done
  local f
  for f in pane wid start_seq; do
    if [[ -z "${!f}" ]]; then
      echo "watch_arm: missing --${f//_/-}" >&2
      return 2
    fi
  done

  local live rec state live_wid
  live=$(watch_get_live "$pane")
  [[ -n "$live" ]] || { echo "watch_arm: pane $pane has no live watch" >&2; return 1; }
  live_wid=$(printf '%s' "$live" | jq -r .watch_id)
  [[ "$live_wid" == "$wid" ]] || {
    echo "watch_arm: watch_id $wid does not match live watch $live_wid on $pane" >&2
    return 1
  }
  state=$(printf '%s' "$live" | jq -r .state)
  [[ "$state" == "pending" ]] || {
    echo "watch_arm: watch $wid is in state $state, expected pending" >&2
    return 1
  }

  # Seed last_evidence_ms at arm — it marks the start of the fresh-evidence
  # window used by the degraded-fallback silence detector (spec: Degraded
  # fallback). Prearm itself is never evidence, but arm is the earliest
  # point at which the daemon expects fresh evidence to arrive.
  local now
  now=$(_eventsd_now_ms)
  rec=$(printf '%s' "$live" | jq -c \
    --argjson start_seq "$start_seq" \
    --argjson now "$now" \
    '.state = "armed"
     | .start_seq = $start_seq
     | .last_evidence_ms = $now
     | .degraded_since_ms = null
     | .last_reconcile_ms = null')
  _eventsd_write_record "$wid" "$rec"
  # Spec: "The daemon records start_seq and immediately re-evaluates
  # buffered evidence." Pre-arm fresh evidence can resolve the watch here.
  _eventsd_flush_buffer "$wid"
}

# _eventsd_clear_live <pane>
# Removes the pane's live-index pointer. Idempotent.
_eventsd_clear_live() {
  local live_file
  live_file=$(_eventsd_live_file "$1")
  rm -f "$live_file"
}

# _eventsd_close <watch_id> <pane> <reason>
# Marks a watch as closed with a reason and frees the pane's live slot.
# Internal helper used by watch_pending_timeout, watch_remove, and
# delivery exhaustion.
_eventsd_close() {
  local wid="$1" pane="$2" reason="$3"
  local rec cur
  cur=$(watch_get "$wid")
  [[ -n "$cur" ]] || { echo "_eventsd_close: no record for $wid" >&2; return 1; }
  rec=$(printf '%s' "$cur" | jq -c \
    --arg reason "$reason" \
    '.state = "closed" | .close_reason = $reason')
  _eventsd_write_record "$wid" "$rec"
  _eventsd_clear_live "$pane"
  # Closing discards any pre-arm buffered evidence — a closed watch never
  # re-arms, so the buffer would otherwise leak.
  rm -f "$(_eventsd_buffer_file "$wid")"
}

# watch_pending_timeout <watch_id>
# Close a pending watch because watch.start never arrived. Refuses to
# act on watches in any other state — once armed, the daemon is past
# the prearm deadline.
watch_pending_timeout() {
  local wid="$1"
  [[ -n "$wid" ]] || { echo "watch_pending_timeout: missing watch_id" >&2; return 2; }
  local cur state pane
  cur=$(watch_get "$wid")
  [[ -n "$cur" ]] || { echo "watch_pending_timeout: no record for $wid" >&2; return 1; }
  state=$(printf '%s' "$cur" | jq -r .state)
  [[ "$state" == "pending" ]] || {
    echo "watch_pending_timeout: watch $wid is in state $state, expected pending" >&2
    return 1
  }
  pane=$(printf '%s' "$cur" | jq -r .pane_id)
  _eventsd_close "$wid" "$pane" "pending_timeout"
}

# watch_remove <pane>
# Explicit removal (spec: "closes an unresolved watch without
# delivery"). Acts on the pane's live watch in pending or armed; no-op
# if there is no live watch.
watch_remove() {
  local pane="$1"
  [[ -n "$pane" ]] || { echo "watch_remove: missing pane" >&2; return 2; }
  local cur state wid
  cur=$(watch_get_live "$pane")
  [[ -n "$cur" ]] || return 0
  state=$(printf '%s' "$cur" | jq -r .state)
  case "$state" in
    pending|armed) ;;
    *)
      echo "watch_remove: watch is in state $state, cannot remove" >&2
      return 1
      ;;
  esac
  wid=$(printf '%s' "$cur" | jq -r .watch_id)
  _eventsd_close "$wid" "$pane" "removed"
}

# watch_resolve <watch_id> <terminal_state>
#
# Promote an armed watch to `resolved` (spec: canonical resolver). The
# watch is one-shot: later resolve calls for the same watch_id are
# ignored so duplicate evidence cannot fire a second notification.
#
# Evidence semantics (fresh/baseline/source) are the resolver bead's
# job. Bead 2 only owns the state transition.
watch_resolve() {
  local wid="$1" terminal="${2:-}"
  [[ -n "$wid" ]] || { echo "watch_resolve: missing watch_id" >&2; return 2; }
  [[ -n "$terminal" ]] || { echo "watch_resolve: missing terminal state" >&2; return 2; }
  local cur state
  cur=$(watch_get "$wid")
  [[ -n "$cur" ]] || { echo "watch_resolve: no record for $wid" >&2; return 1; }
  state=$(printf '%s' "$cur" | jq -r .state)
  case "$state" in
    armed) ;;
    resolved|delivering|delivery_failed|delivered|closed)
      # One-shot: ignore later evidence for this watch_id.
      return 0
      ;;
    *)
      echo "watch_resolve: watch $wid is in state $state, cannot resolve" >&2
      return 1
      ;;
  esac
  local rec pane
  rec=$(printf '%s' "$cur" | jq -c \
    --arg terminal "$terminal" \
    '.state = "resolved"
     | .resolved_state = $terminal
     | .delivery_attempts = 0')
  _eventsd_write_record "$wid" "$rec"
  # Resolved watches are draining (spec: Live and draining watches). Free
  # the pane's live slot and move the watch to the draining ledger so a
  # later turn.prearm does not block on it.
  #
  # Attention publication is not our job — watch_resolve is a state
  # transition. The canonical producer (fast-evidence terminal branch in
  # watch_feed_evidence) owns writing the attention record with the
  # transcript cursor that came in on the evidence event.
  pane=$(printf '%s' "$cur" | jq -r .pane_id)
  _eventsd_clear_live "$pane"
  _eventsd_add_draining "$pane" "$wid"
}

# watch_deliver_attempt <watch_id>
#
# Drive one delivery attempt from the daemon. Legal entry states:
# `resolved` (first attempt) or `delivery_failed` (retry). The watch
# transitions through `delivering` (persisted before invoking the
# external deliver command, per spec), then to `delivered` on success
# or `delivery_failed` on non-zero exit. Each attempt reuses the same
# watch_id (idempotency key). Exhausting MAX_DELIVERY_ATTEMPTS closes
# the watch with close_reason=delivery_exhausted.
watch_deliver_attempt() {
  local wid="$1"
  [[ -n "$wid" ]] || { echo "watch_deliver_attempt: missing watch_id" >&2; return 2; }
  local cur state pane spawner attempts max cmd
  cur=$(watch_get "$wid")
  [[ -n "$cur" ]] || { echo "watch_deliver_attempt: no record for $wid" >&2; return 1; }
  state=$(printf '%s' "$cur" | jq -r .state)
  case "$state" in
    resolved|delivery_failed) ;;
    *)
      echo "watch_deliver_attempt: watch $wid is in state $state, not deliverable" >&2
      return 1
      ;;
  esac

  pane=$(printf '%s' "$cur" | jq -r .pane_id)
  spawner=$(printf '%s' "$cur" | jq -r .spawner_pane)
  attempts=$(printf '%s' "$cur" | jq -r '.delivery_attempts // 0')
  max="${MAX_DELIVERY_ATTEMPTS:-5}"
  cmd="${AGENT_DELIVER_CMD:-agent-deliver}"

  # Persist `delivering` before invoking the deliver command. If the
  # daemon crashes between persist and reply, restart recovery can
  # reclassify as delivery_failed and retry with the same watch_id.
  local pre
  pre=$(printf '%s' "$cur" | jq -c '.state = "delivering"')
  _eventsd_write_record "$wid" "$pre"

  # Delivery argv format:
  #   service mode (EVENTSD_DELIVER_MODE=service): cmd <spawner> <body>
  #     — matches the real agent-deliver signature. body carries the
  #     notification text (see _eventsd_build_notification_body).
  #   legacy mode (default): cmd <wid> <spawner>
  #     — preserved for library-mode unit tests that mock agent-deliver
  #     and assert on the logged argv columns. The running service flips
  #     to `service` so real agent-deliver receives (pane, message) as
  #     spec'd.
  local rc=0
  if [[ "${EVENTSD_DELIVER_MODE:-legacy}" == "service" ]]; then
    local body
    body=$(_eventsd_build_notification_body "$cur")
    "$cmd" "$spawner" "$body" >/dev/null 2>&1 || rc=$?
  else
    "$cmd" "$wid" "$spawner" >/dev/null 2>&1 || rc=$?
  fi
  attempts=$((attempts + 1))

  cur=$(watch_get "$wid")
  if [[ "$rc" -eq 0 ]]; then
    local rec
    rec=$(printf '%s' "$cur" | jq -c \
      --argjson attempts "$attempts" \
      '.state = "delivered" | .delivery_attempts = $attempts')
    _eventsd_write_record "$wid" "$rec"
    # Watch left the draining ledger when delivery completed — it is no
    # longer pending/armed (live) nor resolved/delivering/delivery_failed
    # (draining). It is terminal.
    _eventsd_remove_draining "$pane" "$wid"
    return 0
  fi

  if (( attempts >= max )); then
    local rec
    rec=$(printf '%s' "$cur" | jq -c \
      --argjson attempts "$attempts" \
      '.state = "closed"
       | .close_reason = "delivery_exhausted"
       | .delivery_attempts = $attempts')
    _eventsd_write_record "$wid" "$rec"
    _eventsd_remove_draining "$pane" "$wid"
    return 1
  fi

  local rec
  rec=$(printf '%s' "$cur" | jq -c \
    --argjson attempts "$attempts" \
    '.state = "delivery_failed" | .delivery_attempts = $attempts')
  _eventsd_write_record "$wid" "$rec"
  return 1
}

# watch_feed_evidence — canonical resolver for one evidence event.
#
# Flags:
#   --watch-id <id>         (required) target watch
#   --seq <n>               (required) monotonic seq assigned to this event
#   --candidate-state <s>   (required) observed pane state at this event
#   --transcript-cursor <n> (optional) transcript byte cursor at observation
#   --screen-hash <h>       (optional) screen capture hash at observation
#
# Bead 3 minimum: freshness gate only. Non-fresh evidence is ignored. Fresh
# evidence handling (working vs terminal vs baseline) comes with later
# tests in this bead.
watch_feed_evidence() {
  local wid="" seq="" state="" cursor="" hash="" source="fast"
  local has_cursor=0 has_hash=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --watch-id) wid="$2"; shift 2 ;;
      --seq) seq="$2"; shift 2 ;;
      --candidate-state) state="$2"; shift 2 ;;
      --transcript-cursor) cursor="$2"; has_cursor=1; shift 2 ;;
      --screen-hash) hash="$2"; has_hash=1; shift 2 ;;
      --source) source="$2"; shift 2 ;;
      *) echo "watch_feed_evidence: unknown flag: $1" >&2; return 2 ;;
    esac
  done
  case "$source" in
    fast|reconcile) ;;
    *) echo "watch_feed_evidence: invalid --source: $source" >&2; return 2 ;;
  esac
  local f
  for f in wid seq state; do
    if [[ -z "${!f}" ]]; then
      echo "watch_feed_evidence: missing --${f//_/-}" >&2
      return 2
    fi
  done

  local cur cur_state
  cur=$(watch_get "$wid")
  [[ -n "$cur" ]] || { echo "watch_feed_evidence: no record for $wid" >&2; return 1; }
  cur_state=$(printf '%s' "$cur" | jq -r .state)
  case "$cur_state" in
    pending)
      # Pre-arm fresh evidence is buffered and re-evaluated on arm (spec:
      # "Evidence that arrives after turn.prearm and before watch.start is
      # buffered"). Freshness is still evaluated on flush against the
      # captured prearm reference, so staleness filtering happens once.
      _eventsd_buffer_evidence "$wid" "$seq" "$state" \
        "$has_cursor" "$cursor" "$has_hash" "$hash"
      return 0
      ;;
    armed) ;;
    *) return 0 ;;
  esac

  local prearm_seq prearm_cursor prearm_hash baseline
  prearm_seq=$(printf '%s' "$cur" | jq -r .prearm_seq)
  prearm_cursor=$(printf '%s' "$cur" | jq -r .prearm_transcript_cursor)
  prearm_hash=$(printf '%s' "$cur" | jq -r .prearm_screen_hash)
  baseline=$(printf '%s' "$cur" | jq -r .baseline_state)

  # Freshness rule 1: seq must strictly exceed prearm_seq.
  (( seq > prearm_seq )) || return 0
  # Freshness rule 2: evidence must show progress since prearm — either the
  # transcript cursor advanced past the prearm cursor, or the screen hash
  # differs from the prearm hash. Evidence lacking both is not fresh.
  #
  # Reconcile on non-live-resolving states is stricter. A frozen Claude
  # returns the same transcript cursor every reconcile — whether the
  # inspector reports `working` (steez-j815) or the fuzzy `blocked:unknown`
  # (steez-ymcx: Claude's "Esc to cancel" working indicator is
  # conservatively classified as blocked:unknown by `screen_blocked_state`).
  # In both cases the only ground-truth liveness signal is the transcript
  # cursor: require strict advance over BOTH the prearm cursor AND the
  # most recent reconcile observation before accepting the evidence as
  # fresh. Screen hashes are ignored on this branch — a per-tick hash
  # cannot prove liveness.
  local fresh=0
  if [[ "$source" == "reconcile" ]] \
    && [[ "$state" == "working" || "$state" == "blocked:unknown" ]]; then
    local last_recon_cursor
    last_recon_cursor=$(printf '%s' "$cur" | jq -r '.last_reconcile_cursor // 0')
    if (( has_cursor )) \
      && (( cursor > prearm_cursor )) \
      && (( cursor > last_recon_cursor )); then
      fresh=1
    fi
  else
    if (( has_cursor )) && (( cursor > prearm_cursor )); then
      fresh=1
    fi
    if (( has_hash )) && [[ "$hash" != "$prearm_hash" ]]; then
      fresh=1
    fi
  fi
  (( fresh )) || return 0

  # Fresh fast-path evidence returns the watch to healthy. A degraded
  # reconcile with an advancing transcript cursor is also liveness proof —
  # the worker is demonstrably producing output, so the deadman window must
  # restart from that proof instead of timing out to blocked:unknown. This
  # applies to both `working` (inspector agrees) and the fuzzy
  # `blocked:unknown` (inspector can't tell, but transcript growth is
  # ground truth — steez-ymcx).
  if [[ "$source" == "fast" ]] \
    || { [[ "$source" == "reconcile" ]] \
      && [[ "$state" == "working" || "$state" == "blocked:unknown" ]]; }; then
    local now
    now=$(_eventsd_now_ms)
    cur=$(printf '%s' "$cur" | jq -c \
      --argjson now "$now" \
      '.last_evidence_ms = $now
       | .degraded_since_ms = null
       | .last_reconcile_ms = null
       | .indeterminate_logged = null')
    _eventsd_write_record "$wid" "$cur"
  fi

  # `working` can keep the watch open but never resolves (spec rule 2).
  [[ "$state" == "working" ]] && return 0
  # `blocked:unknown` is fuzzy runtime evidence. Keep it available for
  # explain surfaces, but reserve live-watch resolution for explicit
  # timeout and pane-close fallback only.
  _eventsd_live_resolving_state "$state" || return 0
  # Baseline is never evidence: a live-resolving terminal state matching baseline does not
  # resolve the watch (spec: Baseline rules).
  [[ "$state" == "$baseline" ]] && return 0
  # First fresh live-resolving terminal state different from baseline_state resolves.
  local pane spawner
  pane=$(printf '%s' "$cur" | jq -r .pane_id)
  spawner=$(printf '%s' "$cur" | jq -r '.spawner_pane // empty')
  watch_resolve "$wid" "$state"
  _eventsd_record_attention "$pane" "$state" "eventsd" "${cursor:-}" "" "" "$spawner"
}

# _eventsd_reconcile <pane>
# One reconciliation pass via agent-state (spec: Degraded fallback —
# "Deadman reconciliation uses the same canonical states and the same
# terminal rule as fast evidence"). Prints the reported canonical state,
# or nothing on failure. Command is configurable so tests can inject a
# deterministic mock without touching PATH.
_eventsd_reconcile() {
  local pane="$1"
  local cmd="${AGENT_STATE_CMD:-agent-state}"
  local out state
  out=$("$cmd" "$pane" 2>/dev/null) || return 1
  state=$(printf '%s' "$out" | jq -r '.state // empty' 2>/dev/null)
  [[ -n "$state" ]] || return 1
  printf '%s' "$state"
}

# watch_tick <watch_id>
#
# Drive the degraded-fallback state machine for one armed watch against
# the current clock (spec: Degraded fallback). One call is one "tick" —
# tests drive ticks manually via the fake clock (EVENTSD_NOW_MS); a real
# daemon would call this on a timer.
#
# Per spec:
#   - silence past SILENCE_WINDOW_MS transitions the watch to degraded;
#   - in degraded, agent-state <pane> runs every RECONCILE_INTERVAL_MS and
#     its result is fed through the canonical resolver (no second state
#     machine);
#   - a degraded episode that stays indeterminate past
#     INDETERMINATE_TIMEOUT_MS logs once and keeps reconciling — it must
#     not mature the live watch to terminal blocked:unknown (steez-fyjy).
#     Only real live-resolving terminal evidence (idle / blocked:question /
#     blocked:permission) or a pane-close event closes the watch.
#
# Non-armed watches are a no-op — the degraded machinery is irrelevant
# for pending/draining/terminal states.
watch_tick() {
  local wid="$1"
  [[ -n "$wid" ]] || { echo "watch_tick: missing watch_id" >&2; return 2; }
  local rec state
  rec=$(watch_get "$wid")
  [[ -n "$rec" ]] || return 0
  state=$(printf '%s' "$rec" | jq -r .state)
  [[ "$state" == "armed" ]] || return 0

  local now last_evidence degraded_since last_reconcile pane
  now=$(_eventsd_now_ms)
  last_evidence=$(printf '%s' "$rec" | jq -r '.last_evidence_ms // 0')
  degraded_since=$(printf '%s' "$rec" | jq -r '.degraded_since_ms // 0')
  last_reconcile=$(printf '%s' "$rec" | jq -r '.last_reconcile_ms // 0')
  pane=$(printf '%s' "$rec" | jq -r .pane_id)

  local silence_window reconcile_interval indeterminate_timeout
  silence_window="${SILENCE_WINDOW_MS:-30000}"
  reconcile_interval="${RECONCILE_INTERVAL_MS:-5000}"
  indeterminate_timeout="${INDETERMINATE_TIMEOUT_MS:-120000}"

  # Detect the healthy->degraded transition. Silence is measured from the
  # most recent fast-path evidence (arm seeds the baseline).
  if (( degraded_since == 0 )); then
    if (( now - last_evidence >= silence_window )); then
      degraded_since=$now
      rec=$(printf '%s' "$rec" | jq -c \
        --argjson t "$degraded_since" '.degraded_since_ms = $t')
      _eventsd_write_record "$wid" "$rec"
    else
      return 0
    fi
  fi

  # Indeterminate-window diagnostic (steez-fyjy): a degraded episode that
  # runs past INDETERMINATE_TIMEOUT_MS without fresh terminal evidence used
  # to mature to blocked:unknown and deliver. That path resolved live
  # watches while the worker was still producing output, freed the pane's
  # live slot, and then silently dropped the real Stop-hook idle ping.
  # The live watch must stay armed indefinitely — only idle,
  # blocked:question, blocked:permission, pane close, or explicit remove
  # retire it. Log once per episode so operators can still see long
  # indeterminate stretches without the daemon fabricating a terminal.
  if (( now - degraded_since >= indeterminate_timeout )) \
    && (( last_reconcile != 0 )); then
    local logged
    logged=$(printf '%s' "$rec" | jq -r '.indeterminate_logged // 0')
    if (( logged == 0 )); then
      printf 'agent-eventsd: watch %s (pane %s) past indeterminate window; staying armed pending terminal evidence\n' \
        "$wid" "$pane" >&2
      rec=$(printf '%s' "$rec" | jq -c '.indeterminate_logged = 1')
      _eventsd_write_record "$wid" "$rec"
    fi
  fi

  # Run a reconcile if one is due. First reconcile (last_reconcile == 0) is
  # due immediately on entering degraded.
  if (( last_reconcile == 0 || now - last_reconcile >= reconcile_interval )); then
    local cmd out observed seq cursor tpath
    cmd="${AGENT_STATE_CMD:-agent-state}"
    # --detail (steez-j815): agent-state only emits .detail.transcript_path
    # when --detail is passed. The reconcile cursor depends on this field,
    # so omitting --detail leaves cursor=0 and every freshness check fails.
    out=$("$cmd" "$pane" --detail 2>/dev/null || true)
    if [[ -z "$out" ]]; then
      # Inspector failure (steez-j815). Log so operators see the broken
      # inspector, and do NOT stamp last_reconcile_ms — the indeterminate
      # timeout safety gate depends on zero-observation silence staying
      # visible here (case A). Otherwise a silent inspector matures to a
      # spurious blocked:unknown and the spawner goes blind to the real
      # completion.
      printf 'agent-eventsd: reconcile inspector returned empty output for pane %s (watch %s)\n' \
        "$pane" "$wid" >&2
    else
      observed=$(printf '%s' "$out" | jq -r '.state // empty' 2>/dev/null || true)
      # Real transcript cursor (steez-j815). Replace the synthetic
      # `hash="degraded-$now"` token with a byte count of the pane's
      # transcript file — the only observation we have that is actually
      # anchored to worker progress. A frozen Claude returns the same
      # cursor on every reconcile; the freshness gate now requires a
      # strict advance over both prearm and the last reconcile cursor
      # before accepting the evidence as fresh liveness proof.
      cursor=0
      tpath=$(printf '%s' "$out" | jq -r '.detail.transcript_path // empty' 2>/dev/null || true)
      if [[ -n "$tpath" && -f "$tpath" ]]; then
        cursor=$(wc -c < "$tpath" 2>/dev/null | tr -d ' ')
        [[ -n "$cursor" ]] || cursor=0
      fi
      if [[ -n "$observed" ]]; then
        seq=$(seq_next "$pane")
        watch_feed_evidence --watch-id "$wid" --seq "$seq" \
          --candidate-state "$observed" --transcript-cursor "$cursor" \
          --source reconcile >/dev/null || true
      fi
      # Stamp reconcile bookkeeping. `last_reconcile_cursor` is the
      # persistent "last observed transcript size" used by the freshness
      # gate to detect frozen workers across reset-to-healthy cycles; it
      # must be stamped on EVERY successful reconcile, not just while
      # degraded, or a fresh working reconcile that clears
      # degraded_since_ms would leave the next episode comparing against
      # a stale 0 and the bug (steez-j815 case B) reappears.
      # `last_reconcile_ms` keeps the pre-existing semantics: stamped only
      # while the episode is still degraded, cleared on return to healthy.
      rec=$(watch_get "$wid")
      state=$(printf '%s' "$rec" | jq -r .state)
      if [[ "$state" == "armed" ]]; then
        rec=$(printf '%s' "$rec" | jq -c \
          --argjson c "$cursor" '.last_reconcile_cursor = $c')
        local degraded_now
        degraded_now=$(printf '%s' "$rec" | jq -r '.degraded_since_ms // 0')
        if (( degraded_now != 0 )); then
          rec=$(printf '%s' "$rec" | jq -c \
            --argjson t "$now" '.last_reconcile_ms = $t')
        fi
        _eventsd_write_record "$wid" "$rec"
      fi
    fi
  fi
}

# watch_pane_close <pane>
# Terminal watcher event for a tmux pane going away (spec: Pane close
# and restart). Applies the per-state transitions for the live watch
# on the pane. Draining watches are untouched — their delivery
# continues against spawner_pane (spec).
#
# Per-state behavior:
#   - pending → close without delivery (reason=pane_closed)
#   - armed   → one final reconciliation; terminal != baseline resolves
#               normally, anything else resolves to blocked:unknown
#   - no live → no-op
watch_pane_close() {
  local pane="$1"
  [[ -n "$pane" ]] || { echo "watch_pane_close: missing pane" >&2; return 2; }
  # Sticky attention (steez-80p4.2): worker-pane death must NOT retire
  # the attention record. The spawner still needs the signal — pane
  # closure is exactly the moment a fast-path resolve would be missed
  # if the dot got cleared. The turn-boundary events (new turn.prearm
  # on the pane, explicit remove) own the clear path; pane-close owns
  # writing a final sticky record through the armed branch below.
  local live state wid
  live=$(watch_get_live "$pane")
  [[ -n "$live" ]] || return 0
  wid=$(printf '%s' "$live" | jq -r .watch_id)
  state=$(printf '%s' "$live" | jq -r .state)
  case "$state" in
    pending)
      _eventsd_close "$wid" "$pane" "pane_closed"
      ;;
    armed)
      # Spec: "an armed watch gets one final reconciliation from
      # transcript data still newer than the prearm cursor ... if that
      # final reconciliation does not prove a terminal state, the watch
      # resolves to blocked:unknown." Delivery then drives normally —
      # spec: "draining delivery continues against the spawner pane",
      # and watch_deliver_attempt already targets spawner_pane.
      #
      # The freshness gate is the real prearm cursor threaded from the
      # watch record (steez-si3.1). A reconciled state whose transcript
      # has not advanced past prearm_cursor is pre-turn evidence — it
      # cannot resolve the current watch. Fall back to blocked:unknown
      # instead of carrying the stale state into resolution.
      local baseline rec_state resolved prearm_cursor cursor spawner
      baseline=$(printf '%s' "$live" | jq -r .baseline_state)
      spawner=$(printf '%s' "$live" | jq -r '.spawner_pane // empty')
      prearm_cursor=$(printf '%s' "$live" | jq -r '.prearm_transcript_cursor // 0')
      cursor=$(_eventsd_capture_transcript_cursor "$pane")
      rec_state=$(_eventsd_reconcile "$pane") || rec_state=""
      if [[ -n "$rec_state" ]] \
        && (( cursor > prearm_cursor )) \
        && [[ "$rec_state" != "working" && "$rec_state" != "$baseline" ]]; then
        resolved="$rec_state"
      else
        resolved="blocked:unknown"
      fi
      watch_resolve "$wid" "$resolved" || return 1
      # Sticky attention (steez-80p4.2). Mirror the fast-path resolve's
      # attention write so the spawner window keeps its dot even after
      # the worker pane is gone. Pane-close resolves are frequently the
      # cases the user most needs to see (tool crash, explicit kill mid-
      # turn), so silently eating the signal here was the worst default.
      _eventsd_record_attention "$pane" "$resolved" "pane_close" \
        "${cursor:-0}" "" "" "$spawner"
      watch_deliver_attempt "$wid" >/dev/null 2>&1 || true
      ;;
  esac
}

# watch_list — print JSONL of every known watch record.
watch_list() {
  local dir="$_EVENTSD_STATE_DIR/watches"
  [[ -d "$dir" ]] || return 0
  local file
  for file in "$dir"/*.json; do
    [[ -f "$file" ]] || continue
    cat "$file"
  done
}

# ----- CLI surface (bead 8) -----
#
# Public entry points for the two-step turn (turn.prearm, watch.start)
# and for manual watch management (remove, list, status). The guard at
# the bottom ensures sourcing still yields a pure library — the
# functions above stay side-effect-free when callers only need the API.
#
# Subcommands:
#   prearm   — create pending watch, print watch_id
#   start    — promote pending → armed
#   remove   — close live watch on a pane
#   list     — print all watch records (JSONL)
#   status   — health probe (state dir present and writable)
#   timeout-pending <wid> — close a pending watch by id (test hook)

_eventsd_capture_screen_hash() {
  local pane="$1"
  if command -v tmux >/dev/null 2>&1; then
    tmux capture-pane -p -t "$pane" 2>/dev/null | shasum 2>/dev/null \
      | awk '{print $1}'
  fi
}

_eventsd_capture_transcript_cursor() {
  local pane="$1" path sz cmd
  cmd="${AGENT_STATE_CMD:-agent-state}"
  # --detail (steez-si3.1): agent-state emits .detail.transcript_path
  # only when --detail is set. Omitting it leaves path="" and pins the
  # captured cursor at 0 — every downstream freshness check on this
  # pane then falls through stale and the watch never resolves via
  # cursor-anchored evidence. Matches the reconcile-path invocation in
  # watch_tick (steez-j815).
  path=$("$cmd" "$pane" --detail 2>/dev/null \
    | jq -r '.detail.transcript_path // empty' 2>/dev/null) || path=""
  if [[ -n "$path" && -f "$path" ]]; then
    sz=$(wc -c < "$path" 2>/dev/null | tr -d ' ')
    printf '%s' "${sz:-0}"
  else
    printf '0'
  fi
}

_cmd_prearm() {
  # Auto-start the long-lived service if it isn't already running. The
  # first client invocation is responsible for standing it up; subsequent
  # ones reuse it (spec: Runtime shape).
  if ! _eventsd_auto_start_service; then
    if _eventsd_requires_explicit_service; then
      echo "agent-eventsd prearm: service unavailable in explicit-service mode" >&2
      return 1
    fi
  fi
  local pane="" spawner="" label="" baseline=""
  local hash="" cursor="" prearm_seq=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --pane) pane="$2"; shift 2 ;;
      --spawner) spawner="$2"; shift 2 ;;
      --label) label="$2"; shift 2 ;;
      --baseline-state) baseline="$2"; shift 2 ;;
      --prearm-screen-hash) hash="$2"; shift 2 ;;
      --prearm-transcript-cursor) cursor="$2"; shift 2 ;;
      --prearm-seq) prearm_seq="$2"; shift 2 ;;
      *) echo "agent-eventsd prearm: unknown flag: $1" >&2; return 2 ;;
    esac
  done
  [[ -n "$pane" ]]     || { echo "agent-eventsd prearm: missing --pane" >&2; return 2; }
  [[ -n "$spawner" ]]  || { echo "agent-eventsd prearm: missing --spawner" >&2; return 2; }
  [[ -n "$label" ]]    || { echo "agent-eventsd prearm: missing --label" >&2; return 2; }
  [[ -n "$baseline" ]] || { echo "agent-eventsd prearm: missing --baseline-state" >&2; return 2; }
  [[ -n "$prearm_seq" ]] || prearm_seq=$(seq_next "$pane")
  if [[ -z "$hash" ]]; then
    hash=$(_eventsd_capture_screen_hash "$pane")
    [[ -n "$hash" ]] || hash="none"
  fi
  [[ -n "$cursor" ]] || cursor=$(_eventsd_capture_transcript_cursor "$pane")
  watch_create_pending \
    --pane "$pane" --spawner "$spawner" --label "$label" \
    --baseline-state "$baseline" \
    --prearm-screen-hash "$hash" \
    --prearm-transcript-cursor "$cursor" \
    --prearm-seq "$prearm_seq"
}

_cmd_start() {
  local pane="" wid="" start_seq=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --pane) pane="$2"; shift 2 ;;
      --watch-id) wid="$2"; shift 2 ;;
      --start-seq) start_seq="$2"; shift 2 ;;
      *) echo "agent-eventsd start: unknown flag: $1" >&2; return 2 ;;
    esac
  done
  [[ -n "$pane" ]] || { echo "agent-eventsd start: missing --pane" >&2; return 2; }
  [[ -n "$wid" ]]  || { echo "agent-eventsd start: missing --watch-id" >&2; return 2; }
  [[ -n "$start_seq" ]] || start_seq=$(seq_next "$pane")
  watch_arm --pane "$pane" --watch-id "$wid" --start-seq "$start_seq"
}

_cmd_remove() {
  [[ $# -ge 1 ]] || { echo "agent-eventsd remove: missing pane" >&2; return 2; }
  watch_remove "$1"
}

# _cmd_ack — retire every attention record for --spawner and refresh
# the spawner-scoped tmux sink + SketchyBar. Does not auto-start the
# service: the ack operates directly on the on-disk attention store and
# the tmux/SketchyBar side-effects are synchronous. A user focusing the
# window wants the dot to clear now, not after a daemon spin-up.
_cmd_ack() {
  local spawner=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --spawner) spawner="$2"; shift 2 ;;
      *) echo "agent-eventsd ack: unknown flag: $1" >&2; return 2 ;;
    esac
  done
  [[ -n "$spawner" ]] || { echo "agent-eventsd ack: missing --spawner" >&2; return 2; }
  _eventsd_ack_spawner_attention "$spawner"
}

_cmd_list() {
  watch_list
}

# Primary-path health probe. Health means the long-lived service is
# alive — not just a writable state dir. Without the service, armed
# watches never tick and notifications never fire, so reporting "ready"
# off state-dir writability alone would mask a silently dead runtime.
# Auto-start lives in _cmd_prearm / _cmd_start; status deliberately does
# not spawn so operators see real liveness.
_cmd_status() {
  if _eventsd_service_alive && [[ -d "$_EVENTSD_STATE_DIR" && -w "$_EVENTSD_STATE_DIR" ]]; then
    echo "ready"
    return 0
  fi
  echo "unavailable" >&2
  return 1
}

# ---------- long-lived service (spec: Runtime shape) ----------
#
# agent-eventsd runs as a per-user long-lived service. One process owns all
# timer-driven transitions and delivery for live/draining watches. The
# existing client subcommands (prearm/start/remove/list/status) persist
# state under $STEEZ_STATE_DIR/eventsd/; the service watches that state and
# drives the lifecycle.
#
# Auto-start: _cmd_prearm and _cmd_start spawn the service in the
# background if no PID file points at a live process. A single sigil file
# (eventsd.pid) enforces the singleton.
#
# Tick cadence: EVENTSD_TICK_INTERVAL_SEC (default 0.5s). Tests override
# this to sub-second so degraded reconciliation picks up fresh idle
# transitions within a reasonable timeout.

_eventsd_service_pid_file() {
  printf '%s/eventsd.pid' "$_EVENTSD_STATE_DIR"
}

_eventsd_service_alive() {
  local f pid
  f=$(_eventsd_service_pid_file)
  [[ -f "$f" ]] || return 1
  pid=$(cat "$f" 2>/dev/null) || return 1
  [[ -n "$pid" ]] || return 1
  kill -0 "$pid" 2>/dev/null
}

_eventsd_requires_explicit_service() {
  [[ "${EVENTSD_REQUIRE_EXPLICIT_SERVICE:-0}" == "1" ]]
}

_eventsd_pane_has_live_agent() {
  local pane="$1"
  [[ -n "$pane" ]] || return 1
  command -v tmux >/dev/null 2>&1 || return 0
  tmux display-message -t "$pane" -p '#{pane_id}' >/dev/null 2>&1 || return 1
  local cmd="${AGENT_STATE_CMD:-agent-state}"
  "$cmd" "$pane" >/dev/null 2>&1
}

_eventsd_auto_start_service() {
  _eventsd_service_alive && return 0
  _eventsd_requires_explicit_service && return 1
  mkdir -p "$_EVENTSD_STATE_DIR"
  # No pre-spawn rm of the pidfile. The kernel flock in _cmd_serve is the
  # singleton; a racing second spawn silently exits 0 when it cannot
  # acquire the lock. The pidfile is overwritten by the winner inside
  # _cmd_serve_locked whether the prior contents were live or stale.
  # Launch a detached `agent-eventsd serve`. Env (STEEZ_STATE_DIR, PATH,
  # HOME, tunables) is inherited. The new process sets its own pgid via
  # setsid so pane-close SIGHUPs against the client do not take it down.
  local self="${BASH_SOURCE[0]}"
  [[ -n "$self" && -f "$self" ]] || self=$(command -v agent-eventsd 2>/dev/null || true)
  [[ -n "$self" ]] || return 1
  if command -v setsid >/dev/null 2>&1; then
    setsid bash "$self" serve </dev/null >/dev/null 2>&1 &
  else
    # macOS does not ship setsid by default; nohup plus backgrounding is
    # sufficient for test harnesses and interactive shells.
    (nohup bash "$self" serve </dev/null >/dev/null 2>&1 &)
  fi
  local i
  for i in $(seq 1 30); do
    _eventsd_service_alive && return 0
    sleep 0.1
  done
  return 1
}

# Build the spawner-facing notification message from a watch record.
# Stays single-line so the fake agents (and any other downstream pane)
# treat it as a single prompt. Delivery copy stays collapsed to
# `attention`; callers inspect with agent-state --explain.
_eventsd_build_notification_body() {
  local rec="$1"
  local pane label
  pane=$(printf '%s' "$rec" | jq -r '.pane_id // ""')
  label=$(printf '%s' "$rec" | jq -r '.label // "agent"')
  printf '[agent-watch] %s (%s) attention' "$pane" "$label"
}

# One pass over the persisted watch store. Armed watches get a tick
# (degraded-fallback state machine); resolved / delivery_failed watches
# get a delivery attempt. Every iteration is best-effort; errors on one
# watch do not abort the loop.
_eventsd_service_iterate() {
  local dir="$_EVENTSD_STATE_DIR/watches"
  [[ -d "$dir" ]] || return 0
  # Snapshot (watch_id, state, pane_id) for every record in a single jq
  # pass. The old loop forked three jq per file per tick (6N/s at 2Hz);
  # this is one jq per tick regardless of N. `$(<"$f")` is a bash-native
  # file read that does not fork. `jq -rR` reads each line raw and
  # `fromjson?` emits nothing for malformed or empty records, so a
  # corrupt or mid-tick-unlinked file skips silently instead of
  # aborting the pass — the per-file `|| continue` tolerance the old
  # loop had, preserved across the collapse. `--slurp` is deliberately
  # avoided: slurping makes one parse error corrupt the whole tick.
  local file wid state pane f
  while IFS=$'\t' read -r wid state pane; do
    [[ -n "$wid" ]] || continue
    file=$(_eventsd_watch_file "$wid")
    if [[ "$state" == "armed" && -n "$pane" ]] && ! _eventsd_pane_has_live_agent "$pane"; then
      watch_pane_close "$pane" >/dev/null 2>&1 || true
      continue
    fi
    case "$state" in
      pending)
        # Prearm reaper (spec: PREARM_TIMEOUT_MS). File mtime is the age
        # anchor — stable because _eventsd_atomic_write preserves write
        # time and watch_arm is the sole rewriter of pending, which
        # transitions out. watch_pending_timeout is the sanctioned
        # closer; call it directly (the CLI wrapper auto-starts the
        # service, irrelevant inside the tick).
        local timeout_ms mtime_ms now_ms age_ms
        timeout_ms="${PREARM_TIMEOUT_MS:-5000}"
        mtime_ms=$(( $(stat -f %m "$file" 2>/dev/null || stat -c %Y "$file" 2>/dev/null || echo 0) * 1000 ))
        now_ms=$(_eventsd_now_ms)
        age_ms=$(( now_ms - mtime_ms ))
        if (( mtime_ms > 0 && age_ms >= timeout_ms )); then
          watch_pending_timeout "$wid" >/dev/null 2>&1 || true
        fi
        ;;
      armed)
        watch_tick "$wid" >/dev/null 2>&1 || true
        # Tick may have resolved the watch via reconcile; if so, drive
        # delivery on the same iteration instead of waiting a full tick.
        state=$(jq -r '.state // empty' "$file" 2>/dev/null) || true
        if [[ "$state" == "resolved" ]]; then
          watch_deliver_attempt "$wid" >/dev/null 2>&1 || true
        fi
        ;;
      delivering)
        # Spec (Pane close and restart): "delivering becomes
        # delivery_failed and retries with the same watch_id." The
        # daemon is file-backed, so a crash between watch_deliver_attempt
        # persisting `delivering` and observing the deliver command's
        # exit leaves state=delivering on disk with delivery_attempts
        # already incremented. Overwrite state in place so the retry
        # budget is preserved; watch_deliver_attempt then re-enters the
        # retry path on the same iteration.
        local rec
        rec=$(jq -c '.state = "delivery_failed"' "$file")
        _eventsd_write_record "$wid" "$rec"
        watch_deliver_attempt "$wid" >/dev/null 2>&1 || true
        ;;
      resolved|delivery_failed)
        watch_deliver_attempt "$wid" >/dev/null 2>&1 || true
        ;;
    esac
  done < <(
    {
      for f in "$dir"/*.json; do
        [[ -f "$f" ]] || continue
        printf '%s\n' "$(<"$f")"
      done
    } 2>/dev/null | jq -rR 'fromjson? | [.watch_id // "", .state // "", .pane_id // ""] | @tsv' 2>/dev/null || true
  )
}

_cmd_serve() {
  mkdir -p "$_EVENTSD_STATE_DIR"
  # Kernel-held singleton. A cooperative pidfile check cannot be made
  # race-free in bash: two concurrent `agent-eventsd serve` callers can
  # both pass the liveness probe and both enter the tick loop (see bead
  # steez-lmqx). flock(2) is the only robust fix.
  #
  # The lock is acquired with LOCK_EX|LOCK_NB on a dedicated lock file.
  # Losers exit 0 silently. The winner forks inside perl: the perl
  # *parent* holds the lock fd and does nothing but waitpid, while the
  # perl child execs into `env EVENTSD_LOCK_HELD=1 bash ... _serve_locked`
  # to run the service.
  #
  # The fork-then-exec model is load-bearing. If the bash service
  # inherited the lock fd directly, every external command it forks
  # (sleep, jq, agent-state, agent-deliver) would inherit it too —
  # flock(2) locks live on the open file description, so any descendant
  # with the fd still open keeps the lock alive. SIGKILLing the bash
  # service then leaves the lock pinned by whichever child happened to
  # be alive at the moment, blocking the next legitimate serve
  # indefinitely. Keeping the lock in perl-parent works because fd >= 3
  # is FD_CLOEXEC by perl's default $^F=2, so execve closes the fd in
  # every descendant of the child and the kernel releases the lock the
  # instant perl exits. Perl forwards TERM/INT/HUP to the service so
  # signalling the flock owner tears everything down cleanly.
  # $STEEZ_STATE_DIR must live on a local filesystem — NFS `flock`
  # semantics are historically flaky (see specs/agent-events.md).
  local lock="$_EVENTSD_STATE_DIR/eventsd.lock"
  exec perl -MFcntl=:flock -e '
    open(my $f, ">", $ARGV[0]) or die "open $ARGV[0]: $!";
    flock($f, LOCK_EX | LOCK_NB) or exit 0;
    my $pid = fork();
    die "fork: $!" unless defined $pid;
    if ($pid == 0) {
      exec { "env" } "env", "EVENTSD_LOCK_HELD=1", @ARGV[1..$#ARGV];
      die "exec: $!";
    }
    for my $s (qw(TERM INT HUP)) {
      $SIG{$s} = sub { kill($s, $pid); };
    }
    my $got;
    do { $got = waitpid($pid, 0); } while ($got == -1 && $!{EINTR});
    exit($got == -1 ? 1 : ($? >> 8));
  ' "$lock" bash "${BASH_SOURCE[0]}" _serve_locked
}

# Internal subcommand. Only reachable via _cmd_serve, which acquires the
# flock and re-execs into this path with EVENTSD_LOCK_HELD=1 set by env(1).
# Humans invoking `_serve_locked` directly would bypass the kernel lock;
# the guard below catches that and exits 2. Not listed in _cmd_usage.
_cmd_serve_locked() {
  [[ "${EVENTSD_LOCK_HELD:-0}" == "1" ]] || {
    echo "agent-eventsd: _serve_locked is an internal subcommand; use 'serve'" >&2
    exit 2
  }
  mkdir -p "$_EVENTSD_STATE_DIR"
  # Optional on-disk log for debugging the service tick loop. Off by
  # default; enable by setting EVENTSD_SERVICE_LOG=<path> before the
  # first client command (so auto-start picks up the env).
  if [[ -n "${EVENTSD_SERVICE_LOG:-}" ]]; then
    exec >>"$EVENTSD_SERVICE_LOG" 2>&1
  fi
  local pidf
  pidf=$(_eventsd_service_pid_file)
  # Pidfile is observability-only under the flock scheme. Overwrite
  # unconditionally — the kernel lock is the mutex, and whatever stale
  # pid the previous holder left behind (if any) is irrelevant.
  echo $$ > "$pidf"
  trap 'rm -f "'"$pidf"'"' EXIT INT TERM

  # Delivery routes through agent-deliver with the real (pane, message)
  # signature when the service owns the loop.
  export EVENTSD_DELIVER_MODE=service

  # Tool resolution: clients install agent-state / agent-deliver under
  # $HOME/.steez/bin, which may not be on the service's PATH. The top of
  # this file defaults AGENT_STATE_CMD / AGENT_DELIVER_CMD to the bare
  # command names (for library-mode unit tests that mock them on PATH);
  # the service prefers the installed absolute paths so the real runtime
  # works without touching the caller's PATH. An explicit non-default
  # value wins (tests can still override).
  if [[ "${AGENT_STATE_CMD:-agent-state}" == "agent-state" && -x "$HOME/.steez/bin/agent-state" ]]; then
    export AGENT_STATE_CMD="$HOME/.steez/bin/agent-state"
  fi
  if [[ "${AGENT_DELIVER_CMD:-agent-deliver}" == "agent-deliver" && -x "$HOME/.steez/bin/agent-deliver" ]]; then
    export AGENT_DELIVER_CMD="$HOME/.steez/bin/agent-deliver"
  fi

  local interval
  interval="${EVENTSD_TICK_INTERVAL_SEC:-0.5}"
  while true; do
    _eventsd_service_iterate
    sleep "$interval" 2>/dev/null || sleep 1
  done
}

_cmd_timeout_pending() {
  local wid="${1:-}"
  [[ -n "$wid" ]] || { echo "agent-eventsd timeout-pending: missing watch_id" >&2; return 2; }
  watch_pending_timeout "$wid"
}

# External fast-path evidence entry point. Hooks (Claude Stop,
# PermissionRequest; Codex equivalents) call this with the pane and the
# canonical state they just observed so the resolver can fire before the
# degraded-fallback silence window ever engages.
#
# Fire-and-forget: the caller has a 5s budget and does not care whether a
# live watch exists or freshness passed. We only reject on bad flags. If
# the pane has no live watch (stale hook, already-resolved turn, superseded
# watch), exit 0 — not an error.
_cmd_evidence() {
  # Auto-start the service (match _cmd_prearm): hook callers may fire
  # before any prearm has stood the daemon up.
  if ! _eventsd_auto_start_service; then
    if _eventsd_requires_explicit_service; then
      echo "agent-eventsd evidence: service unavailable in explicit-service mode" >&2
      return 1
    fi
  fi
  local pane="" state="" cursor="" hash=""
  local has_cursor=0 has_hash=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --pane) pane="$2"; shift 2 ;;
      --state) state="$2"; shift 2 ;;
      --transcript-cursor) cursor="$2"; has_cursor=1; shift 2 ;;
      --screen-hash) hash="$2"; has_hash=1; shift 2 ;;
      *) echo "agent-eventsd evidence: unknown flag: $1" >&2; return 2 ;;
    esac
  done
  [[ -n "$pane" ]]  || { echo "agent-eventsd evidence: missing --pane" >&2; return 2; }
  [[ -n "$state" ]] || { echo "agent-eventsd evidence: missing --state" >&2; return 2; }

  # Fire-and-forget: no live watch means the hook lost the race with
  # resolution or supersession. Not an error.
  local live wid seq
  live=$(watch_get_live "$pane") || true
  [[ -n "$live" ]] || return 0
  wid=$(printf '%s' "$live" | jq -r .watch_id)
  [[ -n "$wid" ]] || return 0

  seq=$(seq_next "$pane")
  local args=(--watch-id "$wid" --seq "$seq" --candidate-state "$state" --source fast)
  (( has_cursor )) && args+=(--transcript-cursor "$cursor")
  (( has_hash ))   && args+=(--screen-hash "$hash")
  watch_feed_evidence "${args[@]}" >/dev/null 2>&1 || true
  return 0
}

_cmd_usage() {
  cat <<'USAGE'
Usage: agent-eventsd <command> [args]

Commands:
  prearm    --pane P --spawner S --label L --baseline-state STATE
            [--prearm-seq N] [--prearm-screen-hash H] [--prearm-transcript-cursor N]
            Create pending watch (turn.prearm). Prints watch_id.
  start     --pane P --watch-id WID [--start-seq N]
            Promote pending → armed (watch.start).
  remove    <pane>      Close the live watch on <pane>.
  ack       --spawner S Retire every attention record for spawner S
                        and refresh the tmux + SketchyBar sink.
  list                  Print every watch record as JSONL.
  status                Primary-path health probe.
  serve                 Run the long-lived service loop (auto-started).
  timeout-pending <wid> Close a pending watch by id.
  evidence  --pane P --state S [--transcript-cursor N] [--screen-hash H]
            Feed fast-path evidence for the pane's live watch. Fire-and-forget.
USAGE
}

_eventsd_main() {
  local cmd="${1:-}"
  [[ -n "$cmd" ]] && shift
  case "$cmd" in
    prearm)          _cmd_prearm "$@" ;;
    start)           _cmd_start "$@" ;;
    remove)          _cmd_remove "$@" ;;
    ack)             _cmd_ack "$@" ;;
    list)            _cmd_list "$@" ;;
    status)          _cmd_status "$@" ;;
    serve)           _cmd_serve "$@" ;;
    _serve_locked)   _cmd_serve_locked "$@" ;;
    timeout-pending) _cmd_timeout_pending "$@" ;;
    evidence)        _cmd_evidence "$@" ;;
    -h|--help|"")    _cmd_usage ;;
    *) echo "agent-eventsd: unknown command: $cmd" >&2; return 2 ;;
  esac
}

# Run CLI only on direct invocation; sourced callers keep the library
# surface untouched so bead-1..7 tests continue to behave.
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  _eventsd_main "$@"
fi
