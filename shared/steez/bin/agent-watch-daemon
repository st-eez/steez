#!/usr/bin/env bash
# agent-watch-daemon — Background watcher for AI agent panes.
#
# RECURSIVE LOOP PREVENTION — HARD ARCHITECTURAL RULE
# ---------------------------------------------------
# This daemon MUST call agent-deliver directly. It MUST NOT call
# agent-send. agent-send auto-registers a watch after every delivery,
# so if the daemon called agent-send to notify a spawner, the daemon
# would register a watch on the spawner, the spawner's next state
# change would fire another notification, which would register
# another watch, forever. The layered agent-deliver primitive exists
# specifically to break this loop: it has no side effects beyond tmux.
#
# Any future edit to this file that introduces a call to agent-send
# is a bug that will cause an infinite notification loop.
#
# Behavior
# --------
# Singleton via PID file at $STATE_DIR/agent-watch-daemon.pid. Second
# invocation detects the running daemon and exits silently. Main loop
# reads the watchlist file fresh each cycle, calls agent-state on each
# entry, and fires a notification when the pane transitions out of its
# baseline into a terminal state (idle or blocked:*). Fired entries are
# removed via atomic tmp+rename. The daemon exits cleanly after the
# watchlist has been empty for EMPTY_CYCLES_EXIT consecutive cycles.
#
# Transient agent-state failures (empty output, parse errors) are
# tolerated up to MAX_STATE_FAILURES consecutive cycles per pane. After
# that, the watch is dropped and logged.

set -uo pipefail

STATE_DIR="${STEEZ_STATE_DIR:-$HOME/.steez/state}"
WATCHES="$STATE_DIR/watches.jsonl"
PIDFILE="$STATE_DIR/agent-watch-daemon.pid"
LOG="$STATE_DIR/agent-watch.log"

AGENT_DELIVER="$HOME/.steez/bin/agent-deliver"
AGENT_STATE="$HOME/.steez/bin/agent-state"
AGENT_HISTORY="$HOME/.steez/bin/agent-history"

POLL_INTERVAL="${AGENT_WATCH_POLL:-10}"
EMPTY_CYCLES_EXIT="${AGENT_WATCH_EMPTY_CYCLES:-3}"
MAX_STATE_FAILURES="${AGENT_WATCH_MAX_STATE_FAILURES:-10}"

mkdir -p "$STATE_DIR"
touch "$WATCHES" "$LOG"

iso_ts() { date -u +%Y-%m-%dT%H:%M:%SZ; }

log_line() {
  local level="$1" component="$2" event="$3"
  printf '%s %s %s %s\n' "$(iso_ts)" "$level" "$component" "$event" >> "$LOG"
}

pane_exists() {
  tmux display-message -t "$1" -p '#{pane_id}' >/dev/null 2>&1
}

process_line_has_agent() {
  local line="$1"
  [[ -n "$line" ]] || return 1

  local cmd
  cmd=$(awk '{ n=split($3, a, "/"); print a[n] }' <<< "$line")
  case "$cmd" in
    claude|codex)
      return 0
      ;;
    node)
      [[ "$line" == *codex* || "$line" == *claude* ]]
      return
      ;;
  esac

  return 1
}

pane_has_known_agent() {
  local pane="$1"
  local pane_pid ps_snapshot proc_line child_line

  pane_pid=$(tmux display-message -t "$pane" -p '#{pane_pid}' 2>/dev/null || true)
  [[ -n "$pane_pid" ]] || return 2

  ps_snapshot=$(ps -eo pid,ppid,command 2>/dev/null || true)
  [[ -n "$ps_snapshot" ]] || return 2

  proc_line=$(awk -v pid="$pane_pid" '$1 == pid { print; exit }' <<< "$ps_snapshot")
  [[ -n "$proc_line" ]] || return 2

  if process_line_has_agent "$proc_line"; then
    return 0
  fi

  while IFS= read -r child_line; do
    [[ -z "$child_line" ]] && continue
    if process_line_has_agent "$child_line"; then
      return 0
    fi
  done < <(awk -v ppid="$pane_pid" '$2 == ppid { print }' <<< "$ps_snapshot")

  return 1
}

# ---- Singleton enforcement ----
if [[ -f "$PIDFILE" ]]; then
  old_pid=$(cat "$PIDFILE" 2>/dev/null || true)
  if [[ -n "${old_pid:-}" ]] && kill -0 "$old_pid" 2>/dev/null; then
    # Another daemon is live. Exit silently (not an error).
    exit 0
  fi
  # Stale PID file — the previous daemon died without cleaning up
  # (SIGKILL, power loss, etc). kill -0 reports no such process, so
  # it is safe to remove the file and claim the role.
  rm -f "$PIDFILE"
fi

echo $$ > "$PIDFILE"
EXIT_REASON="normal"
cleanup() {
  rm -f "$PIDFILE"
  log_line INFO daemon "stopped pid=$$ reason=$EXIT_REASON"
}
trap cleanup EXIT
trap 'EXIT_REASON=signal; exit 0' INT TERM

log_line INFO daemon "started pid=$$ poll=${POLL_INTERVAL}s"

# ---- Atomic watchlist rewrite ----
# Removes a single watch entry by pane. Write-to-tmp + rename. mv(1) on
# the same filesystem is an atomic rename(2); readers never see a
# partially written file.
remove_watch() {
  local pane="$1"
  [[ -f "$WATCHES" ]] || return 0
  local tmp="$WATCHES.tmp.$$"
  if jq -c --arg p "$pane" 'select(.pane != $p)' "$WATCHES" > "$tmp" 2>/dev/null; then
    mv "$tmp" "$WATCHES"
  else
    rm -f "$tmp"
  fi
}

# ---- State read helpers ----
read_state() {
  local pane="$1"
  local json
  json=$("$AGENT_STATE" "$pane" 2>/dev/null || true)
  [[ -n "$json" ]] || return 1
  printf '%s' "$json" | python3 -c "import sys,json
try:
    d=json.loads(sys.stdin.read())
    s=d.get('state','')
    if s: print(s)
except: pass" 2>/dev/null
}

# Read the agent's auto-generated turn title from agent-state. The agent
# writes a 1-3 word summary of the current turn to the tmux pane title on
# every turn. agent-state exposes this as the `name` field. Returns the
# title with leading/trailing whitespace stripped, or empty if the title
# is missing or matches one of the known generic placeholders that show
# up before the first real turn renders.
read_title() {
  local pane="$1"
  "$AGENT_STATE" "$pane" 2>/dev/null | python3 -c "
import sys, json
try:
    d = json.loads(sys.stdin.read())
    n = (d.get('name') or '').strip()
    if n.lower() in ('', 'claude code', 'untitled', 'unknown', 'claude', 'ren', 'ren-codex', 'codex'):
        n = ''
    print(n)
except Exception:
    pass
" 2>/dev/null || true
}

# Read the pending question or tool-call for a blocked agent. Used only
# for blocked:* transitions — for idle transitions we rely on the title
# (set by read_title) instead of dumping a chunk of the response, which
# is too noisy for a notification. The full response is always available
# by switching to the pane; the notification is meant to be a ping, not
# a transcript.
read_blocked_detail() {
  local pane="$1" state="$2"
  case "$state" in
    blocked:question|blocked:permission)
      "$AGENT_HISTORY" "$pane" --blocked 2>/dev/null | python3 -c "
import sys, json
try:
    d = json.loads(sys.stdin.read())
    q = d.get('question') or ''
    if not q:
        tool = d.get('tool', '')
        inp = d.get('input', {})
        try:
            inp_str = json.dumps(inp) if not isinstance(inp, str) else inp
        except Exception:
            inp_str = str(inp)
        q = f'{tool}: {inp_str}' if tool else inp_str
    q = ' '.join(q.split())
    print(q[:200])
except Exception:
    pass
" 2>/dev/null || true
      ;;
    blocked:unknown)
      printf 'unknown blocker'
      ;;
    *)
      printf ''
      ;;
  esac
}

# ---- Notification delivery ----
# IMPORTANT: uses agent-deliver, NEVER agent-send. See top-of-file rule.
fire_notification() {
  local pane="$1" spawner="$2" label="$3" new_state="$4" detail="$5"

  # Resolve the target pane to a human-readable session:window.pane
  # address alongside the stable %N pane_id. %N is canonical and never
  # shifts when panes are killed or moved, but it is opaque to a human
  # glancing at a notification. session:window.pane is what the user
  # would type to navigate to the pane, which is the form most people
  # recognize at a glance. We show both.
  #
  # If tmux can no longer resolve the pane (it died between the state
  # read and the fire), we fall back to just the %N so the message
  # still carries the unambiguous identifier.
  local addr id_part
  addr=$(tmux display-message -t "$pane" -p '#{session_name}:#{window_index}.#{pane_index}' 2>/dev/null || true)
  if [[ -n "$addr" ]]; then
    id_part="$pane @ $addr"
  else
    id_part="$pane"
  fi

  # Read the agent's auto-generated turn title at fire time. This is
  # whatever the agent set as the tmux pane title on the most recent turn —
  # typically a 1-3 word summary like "Test complete" or "JWT migration
  # done". The title is the agent's own headline of what it just did,
  # which is more useful than dumping a truncated chunk of the response.
  local title
  title=$(read_title "$pane")

  # Headline fallback chain: pane title -> registration label -> empty.
  # We use the registration-time label only when the title is missing
  # AND the label carries more information than just the agent name
  # (the agent name is already shown separately in the parens).
  local headline=""
  if [[ -n "$title" ]]; then
    headline=" \"$title\""
  elif [[ -n "$label" ]] && [[ "$label" != "$pane" ]]; then
    case "$label" in
      ren|ren-codex|claude|codex|agent) ;;  # bare agent name — already in parens
      *) headline=" \"$label\"" ;;
    esac
  fi

  # The agent type goes in the parens. Prefer the live read from the
  # title call (we already have it parsed); if that failed, fall back to
  # whatever the registration label was, then to "agent".
  local agent_type
  agent_type=$("$AGENT_STATE" "$pane" 2>/dev/null | python3 -c "
import sys, json
try: print(json.loads(sys.stdin.read()).get('agent',''))
except: pass" 2>/dev/null)
  agent_type="${agent_type:-${label%% *}}"
  agent_type="${agent_type:-agent}"

  # Build the message body. Idle = "I finished, glance over". Blocked =
  # "I need an answer, here's what I'm blocked on". The detail field is
  # only populated for blocked transitions (set by the main loop via
  # read_blocked_detail) so the suffix is conditional.
  local body
  body=$(printf '[agent-watch] %s%s (%s) working -> %s' \
    "$id_part" "$headline" "$agent_type" "$new_state")
  if [[ -n "$detail" ]]; then
    body=$(printf '%s. %s' "$body" "$detail")
  fi

  # Two-newline prefix so the notification visually separates from any
  # text the user has in the composer when it arrives.
  local msg
  msg=$(printf '\n\n%s' "$body")

  if "$AGENT_DELIVER" "$spawner" "$msg" >/dev/null 2>&1; then
    log_line INFO daemon "fired spawner=$spawner pane=$pane addr=${addr:-unknown} title=\"${title:-}\" agent=$agent_type transition=working->$new_state"
    return 0
  fi
  local rc=$?
  log_line WARN daemon "delivery failed spawner=$spawner pane=$pane rc=$rc (dropping watch)"
  return "$rc"
}

# ---- Per-pane transient-failure tracker ----
declare -A FAIL_COUNTS

# ---- Main poll loop ----
empty_cycles=0

while true; do
  if [[ ! -s "$WATCHES" ]]; then
    empty_cycles=$((empty_cycles + 1))
    if (( empty_cycles >= EMPTY_CYCLES_EXIT )); then
      EXIT_REASON="watchlist empty for ${EMPTY_CYCLES_EXIT} cycles"
      log_line INFO daemon "exiting: $EXIT_REASON"
      exit 0
    fi
    sleep "$POLL_INTERVAL"
    continue
  fi
  empty_cycles=0

  # Snapshot the file for this cycle. If the file disappears mid-read
  # (e.g., a concurrent rename), cat returns empty and we skip the cycle.
  snapshot=$(cat "$WATCHES" 2>/dev/null || true)
  [[ -n "$snapshot" ]] || { sleep "$POLL_INTERVAL"; continue; }

  # Defense in depth: dedupe by pane, keeping the latest entry per pane.
  snapshot=$(printf '%s' "$snapshot" | jq -c -s 'group_by(.pane) | map(last) | .[]' 2>/dev/null || printf '%s' "$snapshot")

  while IFS= read -r line; do
    [[ -z "$line" ]] && continue

    pane=$(printf '%s' "$line" | jq -r '.pane // empty' 2>/dev/null)
    spawner=$(printf '%s' "$line" | jq -r '.spawner_pane // empty' 2>/dev/null)
    baseline=$(printf '%s' "$line" | jq -r '.baseline_state // "working"' 2>/dev/null)
    label=$(printf '%s' "$line" | jq -r '.label // "agent"' 2>/dev/null)

    [[ -n "$pane" && -n "$spawner" ]] || continue

    cur=$(read_state "$pane" || true)

    if [[ -z "$cur" ]]; then
      # Transient failure (unparseable pane, window resize race, etc).
      # Keep the watch alive while the pane still exists AND a recognized
      # agent is still running there. Drop immediately if the pane lives
      # on after the agent process exits.
      FAIL_COUNTS[$pane]=$(( ${FAIL_COUNTS[$pane]:-0} + 1 ))
      if pane_exists "$pane"; then
        if pane_has_known_agent "$pane"; then
          if (( FAIL_COUNTS[$pane] % MAX_STATE_FAILURES == 0 )); then
            log_line WARN daemon "state read failed for live pane $pane ${FAIL_COUNTS[$pane]} times; retaining watch"
          fi
        else
          agent_rc=$?
          if [[ "$agent_rc" == "1" ]]; then
            log_line WARN daemon "dropping watch on live pane $pane after ${FAIL_COUNTS[$pane]} failed state reads because no recognized agent is running"
            remove_watch "$pane"
            unset "FAIL_COUNTS[$pane]"
          elif (( FAIL_COUNTS[$pane] % MAX_STATE_FAILURES == 0 )); then
            log_line WARN daemon "state read failed for live pane $pane ${FAIL_COUNTS[$pane]} times; agent presence indeterminate, retaining watch"
          fi
        fi
      else
        log_line WARN daemon "dropping watch on missing pane $pane after ${FAIL_COUNTS[$pane]} failed state reads"
        remove_watch "$pane"
        unset "FAIL_COUNTS[$pane]"
      fi
      continue
    fi

    # Reset the failure counter on any successful read.
    FAIL_COUNTS[$pane]=0

    # Transition rule: fire when current != baseline AND current is one
    # of the terminal states. Working -> working stays unchanged. Working
    # -> terminal fires. Non-working baselines also fire on any transition
    # into a terminal state other than themselves (e.g., idle -> blocked).
    if [[ "$cur" != "$baseline" ]]; then
      case "$cur" in
        idle|blocked:question|blocked:permission|blocked:unknown)
          # Detail is only populated for blocked transitions — for idle
          # we use the pane title (read inside fire_notification) as the
          # headline instead of dumping a chunk of the response.
          detail=""
          case "$cur" in
            blocked:*) detail=$(read_blocked_detail "$pane" "$cur") ;;
          esac
          fire_notification "$pane" "$spawner" "$label" "$cur" "$detail" || true
          # One-shot: remove the entry regardless of delivery success.
          # A failed delivery (dead spawner) is logged above and the
          # watch is dropped to avoid looping on a permanently broken
          # target.
          remove_watch "$pane"
          unset "FAIL_COUNTS[$pane]"
          ;;
      esac
    fi
  done <<< "$snapshot"

  sleep "$POLL_INTERVAL"
done
