#!/usr/bin/env bash
# config — read/write ~/.steez/config.yaml
#
# Usage:
#   config get <key>          — read a config value
#   config set <key> <value>  — write a config value
#   config list               — show all config
#
# Env overrides (for testing):
#   STEEZ_STATE_DIR  — override ~/.steez state directory
set -euo pipefail

STATE_DIR="${STEEZ_STATE_DIR:-$HOME/.steez}"
CONFIG_FILE="$STATE_DIR/config"

case "${1:-}" in
  get)
    KEY="${2:?Usage: config get <key>}"
    grep -E "^${KEY}:" "$CONFIG_FILE" 2>/dev/null | tail -1 | awk '{print $2}' | tr -d '[:space:]' || true
    ;;
  set)
    KEY="${2:?Usage: config set <key> <value>}"
    VALUE="${3:?Usage: config set <key> <value>}"
    mkdir -p "$STATE_DIR"
    if grep -qE "^${KEY}:" "$CONFIG_FILE" 2>/dev/null; then
      # Portable in-place edit (BSD sed uses -i '', GNU sed uses -i without arg)
      _tmpfile="$(mktemp "${CONFIG_FILE}.XXXXXX")"
      sed "s/^${KEY}:.*/${KEY}: ${VALUE}/" "$CONFIG_FILE" > "$_tmpfile" && mv "$_tmpfile" "$CONFIG_FILE"
    else
      echo "${KEY}: ${VALUE}" >> "$CONFIG_FILE"
    fi
    ;;
  list)
    cat "$CONFIG_FILE" 2>/dev/null || true
    ;;
  *)
    echo "Usage: config {get|set|list} [key] [value]"
    exit 1
    ;;
esac
