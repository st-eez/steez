#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage: agent-send <pane> "message"

Send a message to a Claude Code, Ren, or Codex CLI pane.

Wraps the chat-pane delayed-Enter footgun: the composer needs Enter as a
separate keystroke after a brief delay, otherwise the message sits in the
input box unsubmitted. This script encodes the working pattern in one place
so callers never need to know the recipe.

Escape safety: messages are sent via tmux load-buffer + paste-buffer, which
passes bytes verbatim — backticks, dollar signs, and quotes survive
unmangled. Multi-line messages need real newlines in the quoted argument
(backslash escapes like \n are sent literally, not interpreted).

Pure fire-and-forget. Reading the response is the caller's job, using
agent-state and `agent-history --last` on their own clock.

Arguments:
  <pane>     Pane id (%N preferred, also accepts session:window.pane)
  <message>  Message body. For multi-line, embed real newlines in a quoted
             string or use a heredoc.

Exit codes:
  0  Message submitted
  1  Generic error (bad args, send failed)
  2  Pane is not a recognized AI agent (prometheus, ren, claude, or codex)
EOF
  exit 0
}

[[ $# -eq 0 ]] && { echo "error: missing arguments" >&2; exit 1; }
case "$1" in -h|--help) usage ;; esac
[[ $# -eq 2 ]] || { echo "error: usage: agent-send <pane> \"message\"" >&2; exit 1; }

# Delegate to the low-level delivery primitive. agent-send is a thin
# wrapper so other tools (e.g. agent-watch) can reuse the delivery recipe
# without inheriting any behavior agent-send layers on top.
exec "$HOME/.steez/bin/agent-deliver" "$@"
