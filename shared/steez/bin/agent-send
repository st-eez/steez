#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage: agent-send <pane> "message"

Send a message to a Claude Code, Ren, or Codex CLI pane.

Wraps the chat-pane delayed-Enter footgun: the composer needs Enter as a
separate keystroke after a brief delay, otherwise the message sits in the
input box unsubmitted. This script encodes the working pattern in one place
so callers never need to know the recipe.

Escape safety: messages are sent via tmux load-buffer + paste-buffer, which
passes bytes verbatim — backticks, dollar signs, and quotes survive
unmangled. Multi-line messages need real newlines in the quoted argument
(backslash escapes like \n are sent literally, not interpreted).

Pure fire-and-forget. Reading the response is the caller's job, using
agent-state and `agent-history --last` on their own clock.

Arguments:
  <pane>     Pane id (%N preferred, also accepts session:window.pane)
  <message>  Message body. For multi-line, embed real newlines in a quoted
             string or use a heredoc.

Exit codes:
  0  Message submitted
  1  Generic error (bad args, send failed)
  2  Pane is not a recognized AI agent (prometheus, ren, claude, or codex)
EOF
  exit 0
}

[[ $# -eq 0 ]] && { echo "error: missing arguments" >&2; exit 1; }
case "$1" in -h|--help) usage ;; esac
[[ $# -eq 2 ]] || { echo "error: usage: agent-send <pane> \"message\"" >&2; exit 1; }

PANE="$1"
MSG="$2"

# Deliver via the low-level primitive. agent-send is the "interactive"
# wrapper — after delivery it also registers a background watch on the
# target pane so the spawner gets notified when the agent finishes.
# Watch registration is a best-effort add-on; a failure here never fails
# the delivery itself.
"$HOME/.steez/bin/agent-deliver" "$PANE" "$MSG"
DELIVER_RC=$?

# Post-delivery watch registration. Runs in a fully detached subshell
# so it does not block the caller — agent-send is still pure
# fire-and-forget from the caller's perspective.
#
# Baseline is hardcoded to "working" (same reasoning as spawn.sh auto-
# registration): the semantic intent of every agent-send call is "notify
# me when the agent finishes THIS message", regardless of what state the
# target was in when the message landed. Observing the post-delivery
# state was the original plan (per the bead description) but it races —
# a fast agent can respond and return to idle before any reasonable
# sleep finishes, leaving us with baseline=idle and a daemon that never
# fires. Hardcoding baseline=working is race-free and always correct:
#   - agent-already-working:     daemon fires on the transition out
#   - agent-fast-responded:      current=idle differs from baseline,
#                                daemon fires on first poll
#   - agent-still-booting/idle:  same as above — correct notification
#
# Label is inferred by agent-watch itself via agent-state (it falls back
# to the agent name when --label is omitted), so no state read is needed
# here either.
if [[ $DELIVER_RC -eq 0 ]] && [[ -n "${TMUX_PANE:-}" ]]; then
  SPAWNER_PANE="$TMUX_PANE"
  (
    "$HOME/.steez/bin/agent-watch" add "$PANE" \
      --spawner "$SPAWNER_PANE" \
      --baseline "working" >/dev/null 2>&1 || true
  ) </dev/null >/dev/null 2>&1 &
  disown 2>/dev/null || true
fi

exit $DELIVER_RC
