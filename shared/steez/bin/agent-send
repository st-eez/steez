#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage: agent-send [--no-watch] [--label <str>] [--spawner <pane>] [--emit-watch-line] <pane> "message"

Send a message to a Claude Code, Ren, or Codex CLI pane.

Wraps the chat-pane delayed-Enter footgun: the composer needs Enter as a
separate keystroke after a brief delay, otherwise the message sits in the
input box unsubmitted. This script encodes the working pattern in one place
so callers never need to know the recipe.

Escape safety: messages are sent via tmux load-buffer + paste-buffer, which
passes bytes verbatim — backticks, dollar signs, and quotes survive
unmangled. Multi-line messages need real newlines in the quoted argument
(backslash escapes like \n are sent literally, not interpreted).

Pure fire-and-forget. Reading the response is the caller's job, using
agent-state and `agent-history --last` on their own clock.

Arguments:
  <pane>     Pane id (%N preferred, also accepts session:window.pane)
  <message>  Message body. For multi-line, embed real newlines in a quoted
             string or use a heredoc.

Options:
  --no-watch         Skip auto-registering a completion watch.
  --label <str>      Override the watch label.
  --spawner <pane>   Override which pane gets the completion notification.
  --emit-watch-line  Print WATCHED=<pane> SPAWNER=<pane> BASELINE=working
                     after a successful watch registration.

Exit codes:
  0  Message submitted
  1  Generic error (bad args, send failed)
  2  Pane is not a recognized AI agent (ren, ren-codex, claude, or codex)
EOF
  exit 0
}

[[ $# -eq 0 ]] && { echo "error: missing arguments" >&2; exit 1; }
case "$1" in -h|--help) usage ;; esac

WATCH=true
WATCH_LABEL=""
SPAWNER_PANE="${TMUX_PANE:-}"
EMIT_WATCH_LINE=false

while [[ $# -gt 0 ]]; do
  case "$1" in
    --no-watch)        WATCH=false; shift ;;
    --label)           WATCH_LABEL="$2"; shift 2 ;;
    --spawner)         SPAWNER_PANE="$2"; shift 2 ;;
    --emit-watch-line) EMIT_WATCH_LINE=true; shift ;;
    -h|--help)         usage ;;
    --)                shift; break ;;
    -*)                echo "error: unknown argument '$1'" >&2; exit 1 ;;
    *)                 break ;;
  esac
done

[[ $# -eq 2 ]] || { echo "error: usage: agent-send [--no-watch] [--label <str>] [--spawner <pane>] [--emit-watch-line] <pane> \"message\"" >&2; exit 1; }

PANE="$1"
MSG="$2"

AGENT_EVENTSD="$HOME/.steez/bin/agent-eventsd"
AGENT_DELIVER="$HOME/.steez/bin/agent-deliver"
AGENT_STATE="$HOME/.steez/bin/agent-state"

# Spec (Watch lifecycle — armed): the two-step turn is
#   1) turn.prearm with baseline_state=working
#   2) deliver the prompt to the pane
#   3) watch.start
# This ordering closes the turn-birth race: fresh evidence observed by
# the daemon after prearm but before start is buffered and re-evaluated
# on start. If step 3 fails, the daemon does NOT auto-retry it — the
# watch stays pending and times out (spec). Delivery is the primary
# contract: watch-wire-up failures never fail the send.
#
# Baseline is hardcoded to "working". The semantic intent of every
# agent-send call is "notify me when the agent finishes THIS message",
# regardless of what state the target was in when the message landed.
# Observing post-delivery state races: a fast agent can respond and
# return to idle before any reasonable sleep finishes. working is
# race-free and always correct — the daemon fires on the transition out.

infer_label() {
  local pane="$1" state_json agent
  state_json=$("$AGENT_STATE" "$pane" 2>/dev/null || true)
  if [[ -n "$state_json" ]]; then
    agent=$(printf '%s' "$state_json" | jq -r '.agent // empty' 2>/dev/null || true)
    if [[ -n "$agent" ]]; then
      printf '%s' "$agent"
      return 0
    fi
  fi
  printf 'agent'
}

WATCH_ID=""
if [[ "$WATCH" == "true" ]] && [[ -n "$SPAWNER_PANE" ]]; then
  LABEL="$WATCH_LABEL"
  [[ -n "$LABEL" ]] || LABEL=$(infer_label "$PANE")
  # turn.prearm — creates a pending watch with the prearm baseline. Any
  # evidence that arrives before watch.start will be buffered and
  # re-evaluated on arm.
  WATCH_ID=$("$AGENT_EVENTSD" prearm \
    --pane "$PANE" \
    --spawner "$SPAWNER_PANE" \
    --label "$LABEL" \
    --baseline-state "working" 2>/dev/null || true)
fi

# Step 2: deliver the prompt. Exit code propagates — delivery is the
# primary contract.
DELIVER_RC=0
"$AGENT_DELIVER" "$PANE" "$MSG" || DELIVER_RC=$?

# Step 3: watch.start. No auto-retry on failure — spec pins this
# explicitly. A failed start leaves the watch pending; pending_timeout
# closes it downstream.
START_RC=0
if [[ -n "$WATCH_ID" ]] && [[ "$DELIVER_RC" -eq 0 ]]; then
  "$AGENT_EVENTSD" start --pane "$PANE" --watch-id "$WATCH_ID" \
    >/dev/null 2>&1 || START_RC=$?
fi

if [[ "$EMIT_WATCH_LINE" == "true" ]] \
   && [[ -n "$WATCH_ID" ]] \
   && [[ "$DELIVER_RC" -eq 0 ]] \
   && [[ "$START_RC" -eq 0 ]]; then
  echo "WATCHED=$PANE SPAWNER=$SPAWNER_PANE BASELINE=working"
fi

exit "$DELIVER_RC"
